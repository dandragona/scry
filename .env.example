# scry secrets — copy this file to `.env` and fill in the values you need.
#   cp .env.example .env   &&   $EDITOR .env
# For an INSTALLED scry (curl | sh), this belongs at ~/.config/scry/.env:
#   mkdir -p ~/.config/scry && cp .env.example ~/.config/scry/.env && chmod 600 ~/.config/scry/.env
# A `.env` next to the scry-deepseek script also works (handy in a cloned repo),
# and $SCRY_ENV_FILE can point at an explicit path. Prefer any of these over an
# `export` in ~/.zshrc — that's read only by interactive shells, so headless
# `scry plan` (Claude Code / cron) won't see it; use ~/.zshenv instead.
# `.env` is gitignored; NEVER commit it. Real environment variables (e.g. an
# `export` or a CI secret) take precedence over anything set here.
#
# The subscription CLIs (claude / codex / agy / kimi) each manage their own login,
# so they need nothing here. The only keys scry itself reads are for its two
# API-key providers: DeepSeek and GLM (Zhipu/Z.ai). Set whichever you use (see
# README, "The API-key providers: DeepSeek and GLM").

# Required ONLY if you use the DeepSeek provider (pay-as-you-go API key from
# https://platform.deepseek.com → API Keys). Loaded by ./scry-deepseek.
DEEPSEEK_API_KEY=

# Optional: override the DeepSeek API base URL (default https://api.deepseek.com).
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Required ONLY if you use the GLM provider (API key from
# https://z.ai/manage-apikey/apikey-list). Loaded by ./scry-glm.
GLM_API_KEY=

# Optional: override the GLM API base URL (default https://api.z.ai/api/paas/v4).
# Use the mainland endpoint if your account is on open.bigmodel.cn:
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Optional: web_search backend (default search_pro_jina; mainland: search_pro/search_std).
# GLM_SEARCH_ENGINE=search_pro_jina
