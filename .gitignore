# --- secrets ---------------------------------------------------------------
# API keys live in the environment or a local .env — NEVER commit them. scry's
# subscription CLIs manage their own login; the only key scry reads is
# DEEPSEEK_API_KEY (optional DeepSeek provider). Copy .env.example -> .env.
.env
.env.*
!.env.example

# --- scry run/eval artifacts ----------------------------------------------
# The DRACO dataset is fetched on demand (see README) — never commit it (~900 KB).
eval/draco-test.jsonl
# Smoke-test outputs are regenerable.
eval/*-smoke.json
eval/draco*.json
# NOTE: eval/dataset.json (curated input) and eval/results.json (committed pilot
# evidence cited by the README) are intentionally tracked — do not ignore them.

# Throwaway run dirs/files if scry is ever invoked from the repo root.
scry-run-*/
scry-msg-*
scry-draco-*/
scry-eval-*/

# Generated plan / research / chat artifacts (scry plan / scry web write these to the
# working dir by default; they're outputs, not source).
scry-plan-*.md
scry-research-*.md
scry-chat-*.md

# The web app's local data lives under ~/.config/scry; ignore any stray in-repo copy
# (e.g. a workspace/project scaffolded inside the repo for testing).
.scry/web/

# Local run history (scry writes here under $HOME, but ignore any stray copy).
.scry/

# Demo recordings (host on asciinema.org or convert to gif; don't bloat the repo).
*.cast

# --- python ----------------------------------------------------------------
__pycache__/
*.py[cod]

# --- os / editor -----------------------------------------------------------
.DS_Store
*.swp
.idea/
.vscode/
