    "max_tool_calls": None,    # uncapped by default; set N to cap claude's web tool-call turns (--max-turns)
    "effort": None,            # reasoning effort; None = each CLI's own default
    "max_output_tokens": None,  # applied where supported (claude only)
    "timeout": DEFAULT_TIMEOUT,  # per-call timeout (s); same default for every phase
    "save_history": True,      # record each run to ~/.scry (scry last / scry log)
