class ProviderError(RuntimeError):
    pass


class AllPanelsFailed(RuntimeError):
    def __init__(self, reason: str, message: str, responses: list):
        super().__init__(message)
        self.failure_reason = reason            # Fusion-style enum
        self.responses = responses


def _effective_timeout(settings: dict) -> float | None:
    """The per-call timeout (seconds), read from a call's resolved (phase) settings;
    falls back to DEFAULT_TIMEOUT when unset. A ceiling — a fast call finishes well under
    it; raising it (e.g. via phases.final for the plan draft) only lets a genuinely slow
    call run longer before being killed.

    Returns None to disable the timeout entirely (no kill — the call runs to completion,
    however long it takes) when the env var SCRY_NO_TIMEOUT is set, or when the resolved
    timeout is negative (e.g. `--timeout -1`, or `"timeout": -1` in config). This is a
    debugging escape hatch for slow, web-heavy agentic calls (e.g. the plan final-draft
    panel) that would otherwise be SIGKILLed mid-flight with all their work discarded.
    A timeout of 0/None still falls back to DEFAULT_TIMEOUT — a stray zero must not
    silently disable the cap and let a run hang forever."""
    if os.environ.get("SCRY_NO_TIMEOUT"):
        return None
    t = settings.get("timeout")
    if t is not None and float(t) < 0:
        return None
    return float(t or DEFAULT_TIMEOUT)


def resolve_command(cmd0: str):
    """Resolve a provider command to a runnable path: PATH first, then a script
    sitting next to scry, then the cwd. Returning an absolute path lets a local
    adapter (e.g. scry-deepseek) run even though proposers execute in a throwaway
    cwd. Returns the path string, or None if nothing executable is found."""
    found = shutil.which(cmd0)
    if found:
        return found
    if os.sep in cmd0 or (os.altsep and os.altsep in cmd0):  # explicit path
        cand = Path(cmd0)
        if cand.is_file() and os.access(str(cand), os.X_OK):
            return str(cand.resolve())
    for base in (Path(__file__).resolve().parent, Path.cwd()):
        cand = base / cmd0
        if cand.is_file() and os.access(str(cand), os.X_OK):
            return str(cand)
    return None


def _provider_repo_safe(p: dict) -> bool:
    """True iff this provider enforces read-only (cannot mutate files) and so may
    run in the user's real repo cwd during `scry plan`. Three mechanisms qualify,
    one per sandboxed panel CLI:

      * claude — `--disallowedTools Bash Edit Write …`  (caps.mutator_disallow)
      * codex  — `--sandbox read-only` baked into its cmd
      * kimi   — a generated agent file that excludes the mutating tools

    An explicit `repo_safe` config key overrides the inference. Anything else —
    e.g. agy/Antigravity, which has NO flag to deny its file-write tool — is
    treated as unsafe and isolated from the repo. Fail closed: an unrecognized
    provider never gets repo access."""
    if "repo_safe" in p:
        return bool(p["repo_safe"])
    if (p.get("caps") or {}).get("mutator_disallow"):
        return True
    cmd = p.get("cmd") or []
    if "--sandbox" in cmd and "read-only" in cmd:
        return True
    if p.get("agent_file"):
        return True
    return False


# --------------------------------------------------------------------------- #
# Deep Research mode — pure helpers (gap detection, stop rule, capability routing).
# Kept side-effect-free so the loop's control flow is unit-testable in isolation.
# --------------------------------------------------------------------------- #

# The judge-analysis keys that represent unresolved work (vs. consensus/insights,
# which are findings, not gaps). A non-empty list under any of these means the
# research loop still has something to chase.
_GAP_KEYS = ("contradictions", "partial_coverage", "blind_spots", "open_questions")


def _has_open_gaps(analysis) -> bool:
    """True iff the research judge's analysis still names something unresolved —
    a contradiction, partially-covered point, blind spot, or open question."""
    if not isinstance(analysis, dict):
        return False
    return any(isinstance(analysis.get(k), list) and analysis.get(k)
               for k in _GAP_KEYS)


def _research_should_continue(analysis, round_idx, target, cap) -> bool:
    """Should the gap loop run another round after completing round `round_idx`
    (0-based)? False at the hard ceiling (`round_idx + 1 >= cap`); otherwise True
    only while the judge still reports open gaps. `target` (the adaptive minimum
    depth) is enforced by the caller, not here — this helper answers the narrower
    "is there anything left to chase, and are we under the cap?" question."""
    if round_idx + 1 >= cap:
        return False
    return _has_open_gaps(analysis)


def _provider_web_capability(provider_name: str, providers: dict) -> str:
    """How a provider can reach the live web, read from config (never the panel
    label): "none" (knowledge-only — explicit no_web marker), "toggle" (web can be
    turned on/off via caps or a web-capable agent file: claude/codex/kimi), or
    "always" (grounding is on and uncontrollable: agy/Gemini). Fail safe: an
    unknown provider is treated as "always" so a live-web gap is never withheld
    from a model that might actually be able to answer it — except the explicit
    no_web set, which is the one place we must not route web gaps."""
    p = providers.get(provider_name) or {}
    if p.get("no_web"):
        return "none"
    caps = p.get("caps") or {}
    if caps.get("web_on") or caps.get("web_off"):
        return "toggle"
    if (p.get("agent_file") or {}).get("exclude_web_off"):
        return "toggle"
    return "always"


def _gap_prompt(questions: list) -> str:
    """Render the routed gaps as the per-member round-2+ prompt: a short directive
    plus the numbered questions this member should investigate."""
    lines = [f"{i + 1}. {q}" for i, q in enumerate(questions)]
    return ("Investigate the following open question(s) from the research so far and "
            "return a condensed, sourced findings brief addressing them:\n"
            + "\n".join(lines))


def _route_gaps(open_questions: list, panel: list, providers: dict) -> list:
    """Re-fan the open gaps to only the capable models. For each panel member:
    web-needing gaps go only to members that can reach the web (capability != "none");
    reasoning-only gaps go to everyone. A member with no gaps assigned to it is
    dropped from the round. Returns [(member, prompt), ...]. Never routes a live-web
    gap to a no-web model (the weak-proposer trap)."""
    web_gaps = [q.get("question", "") for q in open_questions if q.get("needs_web")]
    reason_gaps = [q.get("question", "") for q in open_questions if not q.get("needs_web")]
    tasks = []
    for m in panel:
        has_web = _provider_web_capability(m["provider"], providers) != "none"
        assigned = ([*web_gaps, *reason_gaps] if has_web else list(reason_gaps))
        assigned = [q for q in assigned if q]
        if assigned:
            tasks.append((m, _gap_prompt(assigned)))
    return tasks


def _terminate(proc) -> None:
    """Best-effort kill of a child started with start_new_session=True. The child is
    its own process-group leader (pid == pgid), so we SIGKILL the whole group — that
    reaps any grandchildren the CLI spawned too. Safe to call if it's already gone."""
    if proc is None or proc.returncode is not None:
        return
    try:
        os.killpg(proc.pid, signal.SIGKILL)
    except (ProcessLookupError, PermissionError, OSError):
        try:
            proc.kill()
        except (ProcessLookupError, OSError):
            pass


def _provider_api_keys(cfg: dict) -> set:
    """Every credential env var any provider manages: the union of each provider's
    `env_unset` entries and its `check.requires_env`. Used to strip one vendor's key
    out of every OTHER vendor's child process."""
    keys: set = set()
    for p in cfg.get("providers", {}).values():
        keys.update(p.get("env_unset", []) or [])
        req = (p.get("check") or {}).get("requires_env")
        if req:
            keys.add(req)
    return keys


def _keys_to_scrub(p: dict, cfg: dict) -> set:
    """Credential env vars to remove from THIS provider's child: every managed
    provider key (plus this provider's own declared env_unset) EXCEPT the single key
    this provider legitimately needs. So an exported DEEPSEEK_API_KEY never reaches
    claude/codex/agy/kimi, and ANTHROPIC_API_KEY never reaches the API-key adapters."""
    scrub = _provider_api_keys(cfg) | set(p.get("env_unset", []) or [])
    scrub.discard((p.get("check") or {}).get("requires_env"))
    return scrub


async def call_cli(cfg: dict, provider_name: str, model: str, system: str | None,
                   user: str, cwd: str, depth: int, web: bool, settings: dict,
                   meta: dict | None = None) -> str:
    providers = cfg.get("providers", {})
    if provider_name not in providers:
        raise ProviderError(f"unknown provider '{provider_name}'")
    p = providers[provider_name]
    exe = resolve_command(p["cmd"][0])
    if exe is None:
        raise ProviderError(f"command not found: {p['cmd'][0]}")

    user_text = user
    if system and not p.get("system_flag"):  # fold system into prompt (e.g. codex)
        user_text = system + "\n\n" + user

    # TODO(read-only-hardening): this cwd-isolation is a *temporary* safety measure.
    # A provider with no read-only enforcement (notably agy/Gemini, which auto-
    # approves file writes in headless `-p` mode) is run in a throwaway cwd instead
    # of the user's repo, so it can't read or mutate the project — but it loses repo
    # grounding entirely. The proper fix is to restrict such providers to read-only
    # tools and re-enable repo access. Blocked upstream: agy has no headless tool-
    # restriction yet (google-antigravity/antigravity-cli#45). When it ships:
    # restrict agy's tools + drop the isolation for it. Also still to do: scrub
    # $PWD/$OLDPWD from the child env so the repo path can't leak via the environment.
    iso_cwd = None
    if not _provider_repo_safe(p):
        iso_cwd = tempfile.mkdtemp(prefix="scry-iso-")
        cwd = iso_cwd

    outfile = ""
    if p.get("capture") == "outfile":
        fd, outfile = tempfile.mkstemp(prefix="scry-msg-", suffix=".txt", dir=cwd)
        os.close(fd)

    # Providers that take a generated agent file (kimi) get a temp YAML written here
    # and removed in the finally below, regardless of how the call exits.
    agentfile = ""
    af = p.get("agent_file")
    if af:
        fd, agentfile = tempfile.mkstemp(prefix="scry-agent-", suffix=".yaml")
        os.close(fd)
        Path(agentfile).write_text(render_agent_file(af, web))

    try:
        argv, env_over = render_call(p, model, system, web, settings, outfile,
                                     agentfile=agentfile)
        argv[0] = exe                          # run the resolved path from any cwd

        prompt_is_arg = p.get("prompt") == "arg"
        if prompt_is_arg:                      # prompt goes in argv, not on stdin
            argv = append_prompt_arg(argv, p, user_text)

        env = os.environ.copy()
        for k in _keys_to_scrub(p, cfg):   # don't leak one vendor's key to another
            env.pop(k, None)
        env.update(env_over)
        env["SCRY_DEPTH"] = str(depth + 1)  # recursion guard

        timeout = _effective_timeout(settings)
        try:
            # start_new_session=True puts the child in its own process group so a
            # Ctrl-C/cancel/timeout can kill it (and any grandchildren) explicitly —
            # otherwise a cancelled run leaves a paid CLI running and billing.
            proc = await asyncio.create_subprocess_exec(
                *argv, stdin=asyncio.subprocess.PIPE,
                stdout=asyncio.subprocess.PIPE, stderr=asyncio.subprocess.PIPE,
                env=env, cwd=cwd, start_new_session=True,
            )
        except FileNotFoundError:
            raise ProviderError(f"command not found: {argv[0]}")

        stdin_bytes = b"" if prompt_is_arg else user_text.encode()
        try:
            if timeout is None:           # timeout disabled — run to completion
                out, err = await proc.communicate(stdin_bytes)
            else:
                out, err = await asyncio.wait_for(
                    proc.communicate(stdin_bytes), timeout=timeout)
        except asyncio.TimeoutError:
            _terminate(proc)
            await proc.wait()
            raise ProviderError(f"timeout after {int(timeout)}s")
        except BaseException:             # cancelled (Ctrl-C) or any error: never orphan
            _terminate(proc)
            with contextlib.suppress(BaseException):
                await proc.wait()
            raise

        rc = proc.returncode
        err_txt = err.decode(errors="replace").strip()

        if p.get("capture") == "outfile":
            content = ""
            try:
                content = Path(outfile).read_text(errors="replace").strip()
            except OSError:
                pass
            if not content:
                content = out.decode(errors="replace").strip()
        else:
            raw = out.decode(errors="replace").strip()
            try:
                obj = json.loads(raw)
            except ValueError:
                obj = None
            result_path = p.get("result_path", "result")
            err_field = p.get("error_field")
            if isinstance(obj, dict) and err_field and obj.get(err_field):
                detail = obj.get(result_path) or err_txt or f"exit {rc}"
                raise ProviderError(f"model error: {str(detail)[:200]}")
            if meta is not None:
                meta.update(extract_usage(obj, p))
            content = extract_json_result(raw, result_path)

        if not content:
            raise ProviderError(f"exit {rc}: {err_txt[:300] or 'empty output'}")
        return content
    finally:
        # Remove any temp files on every exit path (success, timeout, error).
        for tmp in (outfile, agentfile):
            if tmp:
                try:
                    os.remove(tmp)
                except OSError:
                    pass
        if iso_cwd:
            shutil.rmtree(iso_cwd, ignore_errors=True)


def _stream_extract(obj: dict, fmt: str) -> tuple:
    """From one parsed stream-event object return (delta_text|None, final_text|None)."""
    if fmt == "claude":
        t = obj.get("type")
        if t == "stream_event":
            ev = obj.get("event") or {}
            if ev.get("type") == "content_block_delta":
                return (ev.get("delta") or {}).get("text"), None
            return None, None
        if t == "result":
            r = obj.get("result")
            return None, (r if isinstance(r, str) else None)
        if t == "assistant":  # full message — a fallback final if no deltas/result
            parts = (obj.get("message") or {}).get("content") or []
            txt = "".join(p.get("text", "") for p in parts
                          if isinstance(p, dict) and p.get("type") == "text")
            return None, (txt or None)
    return None, None


async def stream_call(cfg: dict, provider_name: str, model: str, system: str | None,
                      user: str, cwd: str, depth: int, settings: dict, sink) -> dict:
    """Run one provider call in streaming mode, writing text deltas to `sink` as
    they arrive. Returns {"text": full_answer, "streamed": bool}. Raises
    ProviderError if nothing could be streamed (caller falls back to buffered)."""
    p = cfg["providers"][provider_name]
    fmt = (p.get("stream") or {}).get("format")
    if not fmt:
        raise ProviderError("streaming not supported for this provider")
    if p.get("agent_file"):
        # Streaming doesn't render the generated read-only agent file, which would
        # drop kimi's tool restrictions. Force the buffered path (call_cli) instead.
        raise ProviderError("streaming not supported with an agent_file policy")
    exe = resolve_command(p["cmd"][0])
    if exe is None:
        raise ProviderError(f"command not found: {p['cmd'][0]}")

    user_text = user
    if system and not p.get("system_flag"):
        user_text = system + "\n\n" + user
    argv, env_over = render_call(p, model, system, False, settings, "", stream=True)
    argv[0] = exe

    env = os.environ.copy()
    for k in _keys_to_scrub(p, cfg):   # don't leak one vendor's key to another
        env.pop(k, None)
    env.update(env_over)
    env["SCRY_DEPTH"] = str(depth + 1)

    # Same read-only gate as call_cli (see the TODO there): a provider with no
    # read-only enforcement must not stream in the caller's repo cwd — give it a
    # throwaway cwd instead. (kimi, the only agent_file provider, is already
    # refused above, so the remaining unsafe streamer is agy.)
    iso_cwd = None
    if not _provider_repo_safe(p):
        iso_cwd = tempfile.mkdtemp(prefix="scry-iso-")
        cwd = iso_cwd
    proc = None
    try:
        # Own process group (see call_cli) so a cancel/timeout can't orphan the child.
        proc = await asyncio.create_subprocess_exec(
            *argv, stdin=asyncio.subprocess.PIPE, stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE, env=env, cwd=cwd, start_new_session=True)
        try:
            proc.stdin.write(user_text.encode())
            await proc.stdin.drain()
            proc.stdin.close()
        except (BrokenPipeError, ConnectionResetError, OSError):
            pass  # child already closed stdin / exited — nothing to send; read its output

        timeout = _effective_timeout(settings)
        acc: list = []
        final_text = ""
        streamed_any = False
        meta: dict = {}
        try:
            while True:
                line = (await proc.stdout.readline() if timeout is None
                        else await asyncio.wait_for(
                            proc.stdout.readline(), timeout=timeout))
                if not line:
                    break
                s = line.decode(errors="replace").strip()
                if not s:
                    continue
                try:
                    obj = json.loads(s)
                except ValueError:
                    continue
                meta.update(extract_usage(obj, p))  # populated only by the `result` event
                delta, fin = _stream_extract(obj, fmt)
                if delta:
                    sink(delta)
                    acc.append(delta)
                    streamed_any = True
                if fin:
                    final_text = fin
            await proc.wait()
        except asyncio.TimeoutError:
            _terminate(proc)
            await proc.wait()
            if not streamed_any:
                raise ProviderError(f"stream timeout after {int(timeout)}s")

        text = final_text or "".join(acc)
        if not text:
            raise ProviderError("empty stream output")
        return {"text": text, "streamed": streamed_any, "meta": meta}
    finally:
        # Kill the child on every non-normal exit (cancel/error); a no-op if it
        # already exited. Then clean up the throwaway cwd.
        _terminate(proc)
        if iso_cwd:
            shutil.rmtree(iso_cwd, ignore_errors=True)


