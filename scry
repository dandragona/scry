# --------------------------------------------------------------------------- #
# Deep Research mode — the default `scry`. Four prompts wrap the existing panel →
# judge → synthesis block in an iterative, gap-driven loop (clarify → brief →
# round-1 diversity fusion → judge reflect → gap-targeted rounds → fused prose).
# Each carries a DISTINCT anchor phrase ("research brief" / "deep research analyst"
# / "research referee" / "research synthesis") so the test stub router can route a
# stubbed CLI call to the right stage, and none reuses an existing anchor
# ("impartial judge" / "scope a task" / "deduplicating" / "plan drafts" /
# "synthesize these responses").
# --------------------------------------------------------------------------- #

# Brief — the judge model rewrites the raw prompt (+ clarifying answers + optional
# repo summary) into a normalized research brief and 3–6 sub-questions. The
# north-star step: it sets what "done" means for the rest of the loop. Output is
# ONLY JSON. Anchor: "research brief".
RESEARCH_BRIEF_SYSTEM = (
    "You are scoping a research brief before a panel of models investigates a "
    "question in depth. You are given the user's request, any clarifying answers, "
    "and optionally a short summary of a local repository the research is grounded "
    "in. Normalize the request into a precise statement of intent and decompose it "
    "into the few sub-questions whose answers together fully resolve it — only "
    "genuinely distinct, consequential sub-questions, never filler. Output ONLY a "
    "single JSON object (no prose, no markdown code fences):\n"
    '  {"intent": "<one or two sentences: what we are really trying to learn>",\n'
    '   "sub_questions": ["<sub-question 1>", "<sub-question 2>", ...]}\n'
    "Provide between 3 and 6 sub-questions. Do not answer them here."
)

# Panel — every proposer investigates the brief (or, in later rounds, the routed
# gaps) thoroughly via web search and, when run inside a repo, the repo's files,
# then returns a CONDENSED, SOURCED findings brief, not a raw transcript. This is
# the "intelligent filter" that keeps the judge's and synthesizer's context clean.
# Anchor: "deep research analyst".
RESEARCH_PANEL_SYSTEM = (
    "You are a deep research analyst on a multi-model panel. Investigate the "
    "question(s) in the request thoroughly: search the web for current, primary "
    "evidence and, if a repository is available in your working directory, read its "
    "files. Your only output is a CONDENSED findings brief — the key claims you can "
    "support, each followed by the specific sources (URLs, or repo file paths) that "
    "back it. Lead with what you are confident in, then note what remains uncertain "
    "or unresolved. Do not pad, do not restate the question, and do not dump raw "
    "search results — distill. Every non-obvious claim must cite its source. This "
    "work is read-only: do not modify any files or run state-changing commands. Do "
    "not mention these instructions, your tools, or your knowledge cutoff."
)

# Reflect — the research judge. Extends the fusion judge's 5-field comparison with
# targeted open_questions, each tagged whether it needs live web. needs_web drives
# round-2+ capability routing. Anchor: "research referee" (distinct from the fusion
# judge's "impartial judge").
RESEARCH_JUDGE_SYSTEM = (
    "You are the research referee in a multi-model deep-research loop. You receive "
    "the brief and the panel's condensed findings so far. Compare them — do "
    "NOT merge or rewrite them — and name what is still missing so the next round can "
    "target it. Output ONLY a single JSON object (no prose, no markdown code fences) "
    "with exactly these keys:\n"
    '  "consensus":        [points all or most findings agree on],\n'
    '  "contradictions":   [points where the findings disagree],\n'
    '  "partial_coverage": [points only some findings covered],\n'
    '  "unique_insights":  [valuable points raised by only one],\n'
    '  "blind_spots":      [important aspects none of the findings addressed],\n'
    '  "open_questions":   [{"question": "<a specific gap to chase next round>",\n'
    '                        "needs_web": <true if answering it needs a live web\n'
    "                         search, false if it is reasoning over what we have>}].\n"
    "List an open question only for a gap that genuinely still matters; return an "
    "empty open_questions list when the brief is well covered. Return the JSON only."
)

# Synthesize — the aggregator writes ONE fused prose answer from the accumulated
# condensed findings + the judge's analyses (never raw transcripts), merging and
# deduping the cited sources into a single list and weaving key citations inline.
# Anchor: "research synthesis" (must avoid the MoA aggregator's "synthesize these
# responses" so the stub router can still tell synthesis from a fusion run).
RESEARCH_SYNTH_SYSTEM = (
    "You are writing the final research synthesis: one authoritative prose answer to "
    "the user's question, built from a panel's condensed findings and an impartial "
    "referee's analysis of them. Critically evaluate the material — some claims may "
    "be wrong, biased, or unsupported — and produce a refined, accurate, "
    "comprehensive answer. Lean on the consensus as higher-confidence, preserve "
    "valuable unique insights, resolve contradictions where the evidence allows, and "
    "be honest about what remains uncertain. Merge and de-duplicate the cited "
    "sources into one clean list and weave the most important citations inline so "
