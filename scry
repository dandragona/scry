# Per-phase overrides of DEFAULT_SETTINGS. Each pipeline stage inherits every global
# setting and overrides only the keys it lists here. Resolution per call (later wins):
#   settings -> phases[phase] -> run overlay (phases.final, plan draft only) -> CLI flags.
# The shipped defaults reproduce scry's historical behavior exactly. Overridable keys:
# web_tools, max_tool_calls, timeout, effort, max_output_tokens (save_history is global).
DEFAULT_PHASES = {
    "panel": {},                                       # proposers — inherit globals (web on)
    # judge/synthesis only REASON over the panel's already-gathered output, so they run
    # web-OFF: the heavy web/tool wall-clock belongs to the panelist phases (panel,
    # research) alone. Web-off also keeps the judge's strict-JSON analysis from devolving
    # into the agentic prose/tool ramble that web-on triggers (see the reflect note below).
    "judge": {"web_tools": False},                     # compares panel responses: no web
    "synthesis": {"web_tools": False},                 # fused answer: no web (Fusion behavior)
    "interview": {"web_tools": False},                 # plan/research clarifying rounds: web off
    "final": {"timeout": 2100},                        # plan deep draft: longer ceiling (turns uncapped)
    # Deep Research mode phases (the default `scry`):
    "brief": {"web_tools": False},                     # judge rewrites prompt -> brief: cheap, no web
    "research": {"web_tools": True, "timeout": 2100},  # round fan-out: web on, high budget (slow)
    # The reflect judge reasons over the panel's already-gathered findings and emits a
    # STRICT JSON analysis (the gaps). It runs web-OFF: a live e2e showed that with web
    # tools on, claude goes agentic and pads its result with prose/tool chatter (~15k
