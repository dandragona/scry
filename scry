def numbered_responses(ok_responses: list) -> str:
    return "\n".join(f"{i + 1}. {r['content']}" for i, r in enumerate(ok_responses))


def _failure_reason(failed: list) -> str:
    """Map an all-failed panel onto a Fusion-style failure_reason enum."""
    blob = " ".join((r.get("error") or "").lower() for r in failed)
    if "rate" in blob or "429" in blob or "overloaded" in blob:
        return "rate_limited"
    if "credit" in blob or "insufficient" in blob or "quota" in blob or "balance" in blob:
        return "insufficient_credits"
    return "all_panels_failed"


# A child scry (a model CLI that itself shells out to scry) inherits SCRY_DEPTH+1.
# This ceiling turns an accidental self-invocation loop into a clean error instead of
# an unbounded fork bomb. Normal use is depth 0, so the limit is never hit in practice.
MAX_DEPTH = 4


def _depth_guard() -> int:
    """Read SCRY_DEPTH and abort if scry has recursively invoked itself past
    MAX_DEPTH — the recursion guard SECURITY.md describes."""
    depth = int(os.environ.get("SCRY_DEPTH", "0") or "0")
    if depth > MAX_DEPTH:
        raise SystemExit(
            f"scry: recursion guard tripped (SCRY_DEPTH={depth} > {MAX_DEPTH}) — "
            "scry appears to be invoking itself in a loop; aborting.")
    return depth


async def scry_run(cfg: dict, prompt: str, mode: str, settings: dict, log,
                   stream_final: bool = False, on_stream_start=None,
                   aggregator_system: str | None = None,
                   cwd: str | None = None,
                   cli_overrides: dict | None = None,
                   run_overlay: dict | None = None,
                   panel_system: str | None = None) -> dict:
    # The synthesis system prompt defaults to the canonical MoA aggregator; callers
    # (e.g. `scry plan`) may override it to shape the fused output differently.
    aggregator_system = aggregator_system or MOA_AGGREGATOR_SYSTEM
    # panel_system is the system prompt given to EACH proposer. Default None keeps the
    # panel general-purpose (normal runs answer the prompt as-is); `scry plan` passes
    # PLAN_DRAFTER_SYSTEM so the proposers draft a plan as text instead of trying to
    # execute the task in the (read-only) repo cwd.
    # By default fan out in a fresh scrubbed cwd (no repo-context bleed-in) and remove
    # it after. A caller may pass an existing cwd (e.g. `scry plan --repo`, to let the
    # panel read the codebase); that directory is the user's — NEVER delete it.
    own_cwd = cwd is None
    if own_cwd:
        cwd = tempfile.mkdtemp(prefix="scry-run-")
    depth = _depth_guard()
    # Resolve each stage's settings from globals + its phase override + (for the plan
    # final draft) the `final` run overlay + explicit CLI flags. web is per-stage now.
    phases = cfg.get("phases", {})
    panel_set = _phase_settings(settings, phases, "panel", run_overlay, cli_overrides)
    judge_set = _phase_settings(settings, phases, "judge", run_overlay, cli_overrides)
    synth_set = _phase_settings(settings, phases, "synthesis", run_overlay, cli_overrides)
    panel_web = bool(panel_set.get("web_tools"))
    judge_web = bool(judge_set.get("web_tools"))
    synth_web = bool(synth_set.get("web_tools"))
    run_t0 = time.time()
    meters: list = []  # one usage record per stage invocation (panel/judge/synth)
    try:
        panel = cfg.get("panel", [])
        log(f"▸ panel: {len(panel)} proposers — "
            + ", ".join(m.get("label", m["provider"]) for m in panel)
            + (f"  [web {'on' if panel_web else 'off'}"
               + (f", effort {panel_set['effort']}" if panel_set.get("effort") else "")
               + "]"))

        async def run_one(m: dict) -> dict:
            label = m.get("label", m["provider"])
            t0 = time.time()
            cmeta: dict = {}
            try:
                content = await call_cli(cfg, m["provider"], m.get("model", ""),
                                         panel_system, prompt, cwd, depth, panel_web, panel_set, cmeta)
                dt = time.time() - t0
                log(f"  ✓ {label} ({dt:.0f}s)")
                meters.append({"stage": "panel", "label": label,
                               "provider": m["provider"], "ok": True, **cmeta})
                return {"label": label, "model": m.get("model", ""), "ok": True,
                        "content": content, "error": None, "seconds": round(dt, 1)}
            except Exception as e:  # noqa: BLE001 — one bad proposer must not abort
                dt = time.time() - t0
                log(f"  ✗ {label}: {e}")
                meters.append({"stage": "panel", "label": label,
                               "provider": m["provider"], "ok": False})
                return {"label": label, "model": m.get("model", ""), "ok": False,
                        "content": None, "error": str(e), "seconds": round(dt, 1)}

        responses = await asyncio.gather(*(run_one(m) for m in panel))
        ok = [r for r in responses if r["ok"]]
        if not ok:
            reason = _failure_reason(responses)
            raise AllPanelsFailed(
                reason,
                f"{reason}: every proposer failed "
                + "; ".join(f"{r['label']}: {r['error']}" for r in responses),
                responses)

        numbered = numbered_responses(ok)

        analysis = None
        if mode == "fusion":
            log("▸ judge: comparing responses…")
            j = cfg["judge"]
            juser = (f"User query:\n{prompt}\n\nModel responses:\n{numbered}\n\n"
                     "Return ONLY the JSON object.")
            jmeta: dict = {}
            try:
                jtext = await call_cli(cfg, j["provider"], j.get("model", ""),
                                       JUDGE_SYSTEM, juser, cwd, depth, judge_web, judge_set, jmeta)
                analysis = tolerant_json(jtext)
                if analysis is None:
                    log("  ! judge output was not valid JSON; synthesizing without it")
                meters.append({"stage": "judge", "label": "judge",
                               "provider": j["provider"], "ok": True, **jmeta})
            except Exception as e:  # noqa: BLE001
                log(f"  ! judge failed: {e}; synthesizing without analysis")
                meters.append({"stage": "judge", "label": "judge",
                               "provider": j["provider"], "ok": False})

        log("▸ synthesis: writing the fused answer…")
        a = cfg["aggregator"]
        auser = f"Original user query:\n{prompt}\n\nResponses from models:\n{numbered}"
        if analysis:
            auser += ("\n\nAn impartial judge compared these responses and produced "
                      "this analysis (JSON):\n"
                      + json.dumps(analysis, ensure_ascii=False, indent=2)
                      + "\n\nUse the consensus as higher-confidence, preserve valuable "
                      "unique insights, resolve contradictions where possible, and "
                      "address the noted blind spots.")
        if panel_web:
            auser += ("\n\nThe responses above were produced by models with live web "
                      "access, so rely on their cited evidence as your source of truth. ")
        else:
            auser += "\n\n"
        auser += ("Write the single best final answer to the original query directly — do "
                  "not mention your own tools, your knowledge cutoff, or this synthesis "
                  "process.")
        # Synthesis runs web-off by default (phases.synthesis), matching Fusion. When the
        # caller wants a live answer and the aggregator can stream, type it out token by
        # token; otherwise buffer it. Falls back to buffered if streaming yields nothing
        # (so correctness never depends on the stream parser).
        streamed = False
        a_prov = a["provider"]
        # The stream path renders no web tools, so only stream when synthesis is web-off;
        # if a phase turns synthesis web ON, the buffered path below honors it instead.
        can_stream = (stream_final and not synth_web
                      and (cfg["providers"].get(a_prov) or {}).get("stream"))

        ameta: dict = {}  # shared object: the buffered closure and the stream path both fill it

        async def _buffered() -> str:
            return await call_cli(cfg, a_prov, a.get("model", ""),
                                  aggregator_system, auser, cwd, depth, synth_web, synth_set, ameta)

        if can_stream:
            if on_stream_start:
                on_stream_start()  # tear the orb down before the first token lands
            try:
                r = await stream_call(cfg, a_prov, a.get("model", ""),
                                      aggregator_system, auser, cwd, depth, synth_set,
                                      lambda d: (sys.stdout.write(d), sys.stdout.flush()))
                final, streamed = r["text"], r["streamed"]
                ameta.update(r.get("meta") or {})
                if streamed:
                    sys.stdout.write("\n")
                    sys.stdout.flush()
            except ProviderError:
                final = await _buffered()  # nothing streamed yet -> safe to buffer
        else:
            final = await _buffered()

        meters.append({"stage": "synth", "label": "synth",
                       "provider": a_prov, "ok": True, **ameta})
        cost = summarize_cost(meters, time.time() - run_t0)

        return {
            "status": "ok",
            "prompt": prompt,
            "mode": mode,
            "responses": [{"model": r["label"], "content": r["content"],
                           "ok": r["ok"], "error": r["error"], "seconds": r["seconds"]}
                          for r in responses],
            "analysis": analysis,
            "final": final,
            "streamed": streamed,
            "cost": cost,
        }
    finally:
        if own_cwd:                       # never delete a caller-provided cwd
            shutil.rmtree(cwd, ignore_errors=True)


