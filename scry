# Pipeline
# --------------------------------------------------------------------------- #

def numbered_responses(ok_responses: list) -> str:
    return "\n".join(f"{i + 1}. {r['content']}" for i, r in enumerate(ok_responses))


def _failure_reason(failed: list) -> str:
    """Map an all-failed panel onto a Fusion-style failure_reason enum."""
    blob = " ".join((r.get("error") or "").lower() for r in failed)
    if "rate" in blob or "429" in blob or "overloaded" in blob:
        return "rate_limited"
    if "credit" in blob or "insufficient" in blob or "quota" in blob or "balance" in blob:
        return "insufficient_credits"
    return "all_panels_failed"


# A child scry (a model CLI that itself shells out to scry) inherits SCRY_DEPTH+1.
# This ceiling turns an accidental self-invocation loop into a clean error instead of
# an unbounded fork bomb. Normal use is depth 0, so the limit is never hit in practice.
MAX_DEPTH = 4


def _depth_guard() -> int:
    """Read SCRY_DEPTH and abort if scry has recursively invoked itself past
    MAX_DEPTH — the recursion guard SECURITY.md describes."""
    depth = int(os.environ.get("SCRY_DEPTH", "0") or "0")
    if depth > MAX_DEPTH:
        raise SystemExit(
            f"scry: recursion guard tripped (SCRY_DEPTH={depth} > {MAX_DEPTH}) — "
            "scry appears to be invoking itself in a loop; aborting.")
    return depth


# Short backoff (seconds) before a research panel retry. Module-level so tests can
# zero it out — the value only matters for spacing real CLI calls, never correctness.
_RESEARCH_RETRY_BACKOFF = 2.0


def _is_transient_error(e) -> bool:
    """A panel failure worth one retry in research mode: a timeout or an empty
    response, not a model/auth/usage error (retrying those just burns quota)."""
    s = str(e).lower()
    return ("timeout" in s or "empty output" in s or "empty stream" in s) \
        and "model error" not in s


async def _run_panel(cfg: dict, tasks: list, system: str | None, cwd: str, depth: int,
                     web: bool, settings: dict, log, meters: list,
                     stage: str = "panel", retry: bool = False) -> list:
    """Fan a list of (member, prompt) tasks out in parallel; return one response dict
    per task (in task order). One failed proposer is isolated (ok:False) and never
    aborts the fan-out — the all-fail check is the caller's. With retry=True a single
    transient failure (timeout/empty) is retried once after a short backoff, so deep
    research doesn't silently drop a voice every round; fusion leaves retry off."""
    async def run_one(m: dict, prompt: str) -> dict:
        label = m.get("label", m["provider"])
        t0 = time.time()
        cmeta: dict = {}
        attempt = 0
        while True:
            try:
                content = await call_cli(cfg, m["provider"], m.get("model", ""),
                                         system, prompt, cwd, depth, web, settings, cmeta)
                dt = time.time() - t0
                log(f"  ✓ {label} ({dt:.0f}s)")
                meters.append({"stage": stage, "label": label,
                               "provider": m["provider"], "ok": True,
                               "seconds": round(dt, 1), **cmeta})
                return {"label": label, "model": m.get("model", ""), "ok": True,
                        "content": content, "error": None, "seconds": round(dt, 1)}
            except Exception as e:  # noqa: BLE001 — one bad proposer must not abort
                if retry and attempt == 0 and _is_transient_error(e):
                    attempt += 1
                    log(f"  ↻ {label}: {e} — retrying")
                    await asyncio.sleep(_RESEARCH_RETRY_BACKOFF)
                    cmeta = {}
                    continue
                dt = time.time() - t0
                log(f"  ✗ {label}: {e}")
                meters.append({"stage": stage, "label": label,
                               "provider": m["provider"], "ok": False,
                               "seconds": round(dt, 1), "error": str(e)})
                return {"label": label, "model": m.get("model", ""), "ok": False,
                        "content": None, "error": str(e), "seconds": round(dt, 1)}

    return await asyncio.gather(*(run_one(m, prompt) for m, prompt in tasks))


def _raise_if_all_failed(responses: list) -> list:
    """Return the ok responses, or raise AllPanelsFailed if every proposer failed —
    the shared all-fail guard for both the fusion and research panel fan-outs."""
    ok = [r for r in responses if r["ok"]]
    if not ok:
        reason = _failure_reason(responses)
        raise AllPanelsFailed(
            reason,
            f"{reason}: every proposer failed "
            + "; ".join(f"{r['label']}: {r['error']}" for r in responses),
            responses)
    return ok


async def _run_judge(cfg: dict, judge_system: str, juser: str, cwd: str, depth: int,
                     web: bool, settings: dict, log, meters: list) -> dict | None:
    """One judge call: returns the parsed analysis dict, or None on a parse/CLI
    failure (best-effort — the pipeline proceeds without the analysis rather than
    hard-failing). Shared by fusion's comparison and research's reflect step."""
    j = cfg["judge"]
    jmeta: dict = {}
    t0 = time.time()
    try:
        jtext = await call_cli(cfg, j["provider"], j.get("model", ""),
                               judge_system, juser, cwd, depth, web, settings, jmeta)
        analysis = tolerant_json(jtext)
        if analysis is None:
            log("  ! judge output was not valid JSON; synthesizing without it")
        meters.append({"stage": "judge", "label": "judge",
                       "provider": j["provider"], "ok": True,
                       "seconds": round(time.time() - t0, 1), **jmeta})
        return analysis
    except Exception as e:  # noqa: BLE001
        log(f"  ! judge failed: {e}; synthesizing without analysis")
        meters.append({"stage": "judge", "label": "judge",
                       "provider": j["provider"], "ok": False,
                       "seconds": round(time.time() - t0, 1), "error": str(e)})
        return None


async def _run_synth(cfg: dict, aggregator_system: str, auser: str, cwd: str, depth: int,
                     web: bool, settings: dict, log, meters: list,
                     stream_final: bool = False, on_stream_start=None) -> tuple:
    """Write the fused answer from the prepared `auser`. Streams token-by-token when
    the caller asked for it, synthesis is web-off, and the aggregator can stream;
    otherwise buffers. Falls back to buffered if the stream yields nothing. Returns
    (final_text, streamed). Shared by fusion, plan, and research synthesis."""
    log("▸ synthesis: writing the fused answer…")
    a = cfg["aggregator"]
    a_prov = a["provider"]
    t0 = time.time()
    # The stream path renders no web tools, so only stream when synthesis is web-off;
    # if a phase turns synthesis web ON, the buffered path below honors it instead.
    can_stream = (stream_final and not web
                  and (cfg["providers"].get(a_prov) or {}).get("stream"))
    ameta: dict = {}  # shared object: the buffered closure and the stream path both fill it
    streamed = False

    async def _buffered() -> str:
        return await call_cli(cfg, a_prov, a.get("model", ""),
                              aggregator_system, auser, cwd, depth, web, settings, ameta)

    if can_stream:
        if on_stream_start:
            on_stream_start()  # tear the orb down before the first token lands
        try:
            r = await stream_call(cfg, a_prov, a.get("model", ""),
                                  aggregator_system, auser, cwd, depth, settings,
                                  lambda d: (sys.stdout.write(d), sys.stdout.flush()))
            final, streamed = r["text"], r["streamed"]
            ameta.update(r.get("meta") or {})
            if streamed:
                sys.stdout.write("\n")
                sys.stdout.flush()
        except ProviderError:
            final = await _buffered()  # nothing streamed yet -> safe to buffer
    else:
        final = await _buffered()

    meters.append({"stage": "synth", "label": "synth",
                   "provider": a_prov, "ok": True,
                   "seconds": round(time.time() - t0, 1), **ameta})
    return final, streamed


async def scry_run(cfg: dict, prompt: str, mode: str, settings: dict, log,
                   stream_final: bool = False, on_stream_start=None,
                   aggregator_system: str | None = None,
                   cwd: str | None = None,
                   cli_overrides: dict | None = None,
                   run_overlay: dict | None = None,
                   panel_system: str | None = None,
                   scrub_fuse_cwd: bool = False) -> dict:
    # The synthesis system prompt defaults to the canonical MoA aggregator; callers
    # (e.g. `scry plan`) may override it to shape the fused output differently.
    aggregator_system = aggregator_system or MOA_AGGREGATOR_SYSTEM
    # panel_system is the system prompt given to EACH proposer. Default None keeps the
    # panel general-purpose (normal runs answer the prompt as-is); `scry plan` passes
    # PLAN_DRAFTER_SYSTEM so the proposers draft a plan as text instead of trying to
    # execute the task in the (read-only) repo cwd.
    # By default fan out in a fresh scrubbed cwd (no repo-context bleed-in) and remove
    # it after. A caller may pass an existing cwd (e.g. `scry plan --repo`, to let the
    # panel read the codebase); that directory is the user's — NEVER delete it.
    own_cwd = cwd is None
    depth = _depth_guard()   # before any mkdtemp: a tripped recursion guard raises here,
                             # outside the try/finally, so allocate temp dirs only after it
    if own_cwd:
        cwd = tempfile.mkdtemp(prefix="scry-run-")
    # scrub_fuse_cwd (set by `scry plan`): the PANEL may need the repo (`cwd`), but the
    # judge + synthesis only fuse the drafts they're handed as text — they need neither
    # the repo nor any tools. Run them in a fresh throwaway dir so a web-off synth in an
    # empty cwd makes ZERO tool calls (claude's web-off policy still leaves Read/Grep/Glob,
    # so without this the "final draft" could wander the repo). Always cleaned up.
    fuse_cwd = tempfile.mkdtemp(prefix="scry-fuse-") if scrub_fuse_cwd else cwd
    # Resolve each stage's settings from globals + its phase override + (for the plan
    # final draft) the `final` run overlay + explicit CLI flags. web is per-stage now.
    phases = cfg.get("phases", {})
    panel_set = _phase_settings(settings, phases, "panel", run_overlay, cli_overrides)
    judge_set = _phase_settings(settings, phases, "judge", run_overlay, cli_overrides)
    synth_set = _phase_settings(settings, phases, "synthesis", run_overlay, cli_overrides)
    panel_web = bool(panel_set.get("web_tools"))
    judge_web = bool(judge_set.get("web_tools"))
    synth_web = bool(synth_set.get("web_tools"))
    run_t0 = time.time()
    meters: list = []  # one usage record per stage invocation (panel/judge/synth)
    try:
        panel = cfg.get("panel", [])
        log(f"▸ panel: {len(panel)} proposers — "
            + ", ".join(m.get("label", m["provider"]) for m in panel)
            + (f"  [web {'on' if panel_web else 'off'}"
               + (f", effort {panel_set['effort']}" if panel_set.get("effort") else "")
               + "]"))

        responses = await _run_panel(cfg, [(m, prompt) for m in panel], panel_system,
                                     cwd, depth, panel_web, panel_set, log, meters)
        ok = _raise_if_all_failed(responses)
        numbered = numbered_responses(ok)

        analysis = None
        if mode == "fusion":
            log("▸ judge: comparing responses…")
            juser = (f"User query:\n{prompt}\n\nModel responses:\n{numbered}\n\n"
                     "Return ONLY the JSON object.")
            analysis = await _run_judge(cfg, JUDGE_SYSTEM, juser, fuse_cwd, depth,
                                        judge_web, judge_set, log, meters)

        a = cfg["aggregator"]
        auser = f"Original user query:\n{prompt}\n\nResponses from models:\n{numbered}"
        if analysis:
            auser += ("\n\nAn impartial judge compared these responses and produced "
                      "this analysis (JSON):\n"
                      + json.dumps(analysis, ensure_ascii=False, indent=2)
                      + "\n\nUse the consensus as higher-confidence, preserve valuable "
                      "unique insights, resolve contradictions where possible, and "
                      "address the noted blind spots.")
        if panel_web:
            auser += ("\n\nThe responses above were produced by models with live web "
                      "access, so rely on their cited evidence as your source of truth. ")
        else:
            auser += "\n\n"
        auser += ("Write the single best final answer to the original query directly — do "
                  "not mention your own tools, your knowledge cutoff, or this synthesis "
                  "process.")
        # Synthesis runs web-off by default (phases.synthesis), matching Fusion. When the
        # caller wants a live answer and the aggregator can stream, type it out token by
        # token; otherwise buffer it (helper handles the fallback if the stream is empty).
        final, streamed = await _run_synth(cfg, aggregator_system, auser, fuse_cwd, depth,
                                           synth_web, synth_set, log, meters,
                                           stream_final, on_stream_start)
        cost = summarize_cost(meters, time.time() - run_t0)

        return {
            "status": "ok",
            "prompt": prompt,
            "mode": mode,
            "responses": [{"model": r["label"], "content": r["content"],
                           "ok": r["ok"], "error": r["error"], "seconds": r["seconds"]}
                          for r in responses],
            "analysis": analysis,
            "final": final,
            "streamed": streamed,
            "cost": cost,
        }
    finally:
        if scrub_fuse_cwd:                # the throwaway judge/synth dir is always ours
            shutil.rmtree(fuse_cwd, ignore_errors=True)
        if own_cwd:                       # never delete a caller-provided cwd
            shutil.rmtree(cwd, ignore_errors=True)


# --------------------------------------------------------------------------- #
# Deep Research mode — the iterative, gap-driven orchestrator (the default `scry`).
# Wraps the shared panel/judge/synth helpers in a brief -> round-1 diversity-fusion
# -> reflect -> gap-targeted-rounds -> fused-prose loop. The interactive clarifying
# interview is the CLI layer's job (do_research); research_run takes the gathered
# answers and is otherwise side-effect-free, so the loop is driven by stubs in tests.
# --------------------------------------------------------------------------- #

def _brief_user(prompt: str, answers: list | None, repo_summary: str | None) -> str:
    """The judge's input for the brief step: the request, any clarifying answers, and
    an optional short repo summary, framed as data."""
    parts = [f"User request:\n{prompt}"]
    if answers:
        qa = "\n".join(f"Q: {a.get('q', '')}\nA: {a.get('a', '')}" for a in answers)
        parts.append("Clarifying answers:\n" + qa)
    if repo_summary:
        parts.append("Local repository context (read-only):\n" + repo_summary)
    parts.append("Produce the research brief as the JSON object.")
    return "\n\n".join(parts)


def _brief_prompt(brief: dict) -> str:
    """The round-1 prompt every panelist answers: the full brief (intent + sub-qs)."""
    lines = [f"Research question:\n{brief.get('intent', '')}"]
    subqs = brief.get("sub_questions") or []
    if subqs:
        lines.append("Sub-questions to resolve:\n" + "\n".join(f"- {s}" for s in subqs))
    lines.append("Investigate thoroughly and return your condensed, sourced findings.")
    return "\n\n".join(lines)


def _reflect_user(brief: dict, evidence: list) -> str:
    """The research judge's input: the intent plus the panel's accumulated findings."""
    return (f"Research question:\n{brief.get('intent', '')}\n\n"
            f"Panel findings so far:\n{numbered_responses(evidence)}\n\n"
            "Return ONLY the JSON object.")


def _research_synth_user(brief: dict, evidence: list, analysis: dict | None) -> str:
    """The aggregator's input: the accumulated condensed findings + the referee's
    analysis (never raw transcripts). The findings are web-grounded, so the writer
    leans on their cited evidence and merges the sources into one list."""
    auser = (f"Research question:\n{brief.get('intent', '')}\n\n"
             f"Condensed findings from the panel:\n{numbered_responses(evidence)}")
    if analysis:
        auser += ("\n\nThe research referee's analysis of these findings (JSON):\n"
                  + json.dumps(analysis, ensure_ascii=False, indent=2)
                  + "\n\nLean on the consensus, preserve unique insights, resolve the "
                  "contradictions where the evidence allows, and address the blind spots.")
    auser += ("\n\nThe findings above were produced by models with live web access, so "
              "rely on their cited evidence as your source of truth. Write the single "
              "best researched answer to the question directly, merging and "
              "de-duplicating the cited sources into one clean list.")
    return auser


async def _make_brief(cfg: dict, prompt: str, answers: list | None,
                      repo_summary: str | None, settings: dict, cwd: str, depth: int,
                      log, meters: list) -> dict:
    """Turn the prompt (+ clarifying answers + optional repo summary) into a normalized
    {intent, sub_questions} brief via the judge model. Best-effort: on a CLI/parse
    failure, fall back to a trivial brief over the raw prompt so research still runs."""
    j = cfg["judge"]
    log("▸ brief: scoping the research…")
    bmeta: dict = {}
    obj: dict = {}
    try:
        txt = await call_cli(cfg, j["provider"], j.get("model", ""),
                             RESEARCH_BRIEF_SYSTEM, _brief_user(prompt, answers, repo_summary),
                             cwd, depth, bool(settings.get("web_tools")), settings, bmeta)
        obj = tolerant_json(txt) or {}
        meters.append({"stage": "brief", "label": "brief",
                       "provider": j["provider"], "ok": True, **bmeta})
    except Exception as e:  # noqa: BLE001 — research never hard-fails on the brief
        log(f"  ! brief failed: {e}; using the raw prompt")
        meters.append({"stage": "brief", "label": "brief",
                       "provider": j["provider"], "ok": False})
    intent = (obj.get("intent") or "").strip() or prompt
    subqs = [s.strip() for s in (obj.get("sub_questions") or [])
             if isinstance(s, str) and s.strip()]
    return {"intent": intent, "sub_questions": subqs}


async def research_run(cfg: dict, prompt: str, settings: dict, log,
                       stream_final: bool = False, on_stream_start=None,
                       cwd: str | None = None, cli_overrides: dict | None = None,
                       answers: list | None = None, repo_summary: str | None = None,
                       depth_override: int | None = None,
                       cap_override: int | None = None,
                       seed_meters: list | None = None) -> dict:
    """Run the deep-research loop and return a result dict extending scry_run's with
    `brief` and `rounds: [{responses, analysis}]`. The clarifying interview (if any)
    is done by the caller and passed as `answers`; its `seed_meters` fold into the
    cost tally so the interview's calls aren't silently dropped."""
    own_cwd = cwd is None
    depth = _depth_guard()   # before mkdtemp: a tripped recursion guard raises here,
                             # outside the try/finally, so don't leak a temp dir
    if own_cwd:
        cwd = tempfile.mkdtemp(prefix="scry-research-")
    phases = cfg.get("phases", {})
    rcfg = cfg.get("research", {})
    brief_set = _phase_settings(settings, phases, "brief", None, cli_overrides)
    research_set = _phase_settings(settings, phases, "research", None, cli_overrides)
    reflect_set = _phase_settings(settings, phases, "reflect", None, cli_overrides)
    synth_set = _phase_settings(settings, phases, "synthesis", None, cli_overrides)
    research_web = bool(research_set.get("web_tools"))
    reflect_web = bool(reflect_set.get("web_tools"))
    synth_web = bool(synth_set.get("web_tools"))
    # target = adaptive minimum depth; cap = absolute ceiling. The cap wins: an
    # explicit low --max-rounds clamps the target down rather than being raised to it.
    target = max(1, int(depth_override or rcfg.get("max_rounds", 3) or 3))
    cap = max(1, int(cap_override or rcfg.get("hard_cap", 5) or 5))
    target = min(target, cap)
    early_exit = bool(rcfg.get("early_exit", True))
    providers = cfg.get("providers", {})
    panel = cfg.get("panel", [])
    run_t0 = time.time()
    meters: list = list(seed_meters or [])   # fold the clarify interview's calls into cost
    try:
        brief = await _make_brief(cfg, prompt, answers, repo_summary, brief_set,
                                  cwd, depth, log, meters)
        evidence: list = []
        analysis: dict | None = None
        rounds: list = []
        for i in range(cap):
            if i == 0:
                tasks = [(m, _brief_prompt(brief)) for m in panel]
            else:
                open_qs = (analysis or {}).get("open_questions") or []
                tasks = _route_gaps(open_qs, panel, providers)
                if not tasks:
                    break                               # no gaps left to chase
            log(f"▸ research round {i + 1}: {len(tasks)} proposer(s)"
                + (f"  [web {'on' if research_web else 'off'}]"))
            responses = await _run_panel(cfg, tasks, RESEARCH_PANEL_SYSTEM, cwd, depth,
                                         research_web, research_set, log, meters,
                                         stage="panel", retry=True)
            ok = [r for r in responses if r["ok"]]
            if not ok:
                if not evidence:
                    _raise_if_all_failed(responses)     # round 1 with no evidence: fatal
                log("  ! every proposer failed this round; synthesizing with what we have")
                break
            evidence.extend(ok)
            log("▸ reflect: comparing findings and naming the gaps…")
            analysis = await _run_judge(cfg, RESEARCH_JUDGE_SYSTEM,
                                        _reflect_user(brief, evidence), cwd, depth,
                                        reflect_web, reflect_set, log, meters)
            rounds.append({"responses": responses, "analysis": analysis})
            if (early_exit and (i + 1) >= target
                    and not _research_should_continue(analysis, i, target, cap)):
                break

        auser = _research_synth_user(brief, evidence, analysis)
        final, streamed = await _run_synth(cfg, RESEARCH_SYNTH_SYSTEM, auser, cwd, depth,
                                           synth_web, synth_set, log, meters,
                                           stream_final, on_stream_start)
        cost = summarize_cost(meters, time.time() - run_t0)

        def _shape(rs):
            return [{"model": r["label"], "content": r["content"], "ok": r["ok"],
                     "error": r["error"], "seconds": r["seconds"]} for r in rs]

        return {
            "status": "ok",
            "prompt": prompt,
            "mode": "research",
            "brief": brief,
            "rounds": [{"responses": _shape(rd["responses"]), "analysis": rd["analysis"]}
                       for rd in rounds],
            "responses": _shape(evidence),
            "analysis": analysis,
            "final": final,
            "streamed": streamed,
            "cost": cost,
        }
    finally:
        if own_cwd:                       # never delete a caller-provided cwd
            shutil.rmtree(cwd, ignore_errors=True)


