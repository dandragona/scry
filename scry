# --------------------------------------------------------------------------- #
# Config + small parsers
# --------------------------------------------------------------------------- #

# scry's config describes which subscription CLIs you have and how you like to
# fuse them — a property of your machine + accounts, not of any repo (scry even
# fans out in a scrubbed temp cwd, so it never reads project context). So the
# canonical config lives once per computer at global_config_path(). A project that
# genuinely needs a different panel can drop a LOCAL_CONFIG_NAME beside its code;
# that file is deliberately NOT named the generic "config.json", so a stray
# config.json belonging to some other tool can never be mistaken for scry's.
LOCAL_CONFIG_NAME = "scry.config.json"


def global_config_path() -> Path:
    """The once-per-computer config location. Resolved live (honors $HOME)."""
    return Path.home() / ".config" / "scry" / "config.json"


def load_config(path: str | None) -> dict:
    cfg = copy.deepcopy(DEFAULT_CONFIG)
    # Precedence (first hit wins): explicit --config, else a project-local
    # ./scry.config.json (opt-in override), else the global config.
    candidates = [Path(path)] if path else [
        Path.cwd() / LOCAL_CONFIG_NAME,
        global_config_path(),
    ]
    for c in candidates:
        try:
            if c.exists():
                cfg.update(json.loads(c.read_text()))
                break
        except (OSError, ValueError) as e:
            sys.stderr.write(f"scry: warning: ignoring bad config {c}: {e}\n")
    # Settings always backfilled with defaults so partial overrides are safe.
    cfg["settings"] = {**DEFAULT_SETTINGS, **cfg.get("settings", {})}
    # Same for the top-level `plan` block, so configs predating plan mode still work.
    cfg["plan"] = {**DEFAULT_CONFIG["plan"], **cfg.get("plan", {})}
    # Per-phase overrides: backfill each known phase from DEFAULT_PHASES and merge a
    # user-supplied phase on top of its default, so a partial phase override keeps the
    # sibling phase defaults. Only dict values are phase overrides — a "_note" string
    # (or any other non-dict) is ignored. Unknown phase names are preserved.
    user_phases = cfg.get("phases") or {}
    def _ov(ph):
        v = user_phases.get(ph)
        return v if isinstance(v, dict) else {}
    extra = [p for p in user_phases
             if p not in DEFAULT_PHASES and isinstance(user_phases.get(p), dict)]
    cfg["phases"] = {ph: {**DEFAULT_PHASES.get(ph, {}), **_ov(ph)}
                     for ph in (list(DEFAULT_PHASES) + extra)}
    return cfg


def _phase_settings(settings: dict, phases: dict, phase: str,
                    run_overlay: dict | None = None,
                    cli_overrides: dict | None = None) -> dict:
    """Resolve the effective settings for one pipeline phase. Merge order, later wins:
    base `settings` -> phases[phase] -> run_overlay (phases.final, plan draft only) ->
    cli_overrides (explicit per-run flags, so a flag always wins over a config phase)."""
    return {**settings,
            **((phases or {}).get(phase) or {}),
            **(run_overlay or {}),
            **(cli_overrides or {})}


def _cli_overrides(args) -> dict:
    """The settings keys the user set explicitly on the command line. Only present keys
    are returned, so an unset flag never clobbers a config/phase value. Applied last in
    _phase_settings, so an explicit flag wins over every per-phase override."""
    o: dict = {}
    if getattr(args, "no_web", False):
        o["web_tools"] = False
    if getattr(args, "effort", None):
        o["effort"] = args.effort
    if getattr(args, "max_tool_calls", None) is not None:
        o["max_tool_calls"] = args.max_tool_calls
    if getattr(args, "max_output_tokens", None) is not None:
        o["max_output_tokens"] = args.max_output_tokens
    if getattr(args, "timeout", None) is not None:
        o["timeout"] = args.timeout
    return o


def parse_member(spec: str) -> dict:
    """'claude:opus' -> {'provider':'claude','model':'opus'}; 'codex' -> model ''."""
    spec = spec.strip()
    prov, _, model = spec.partition(":")
    return {"provider": prov.strip(), "model": model.strip()}


def parse_panel(spec: str) -> list:
    members = []
    for item in spec.split(","):
        item = item.strip()
        if not item:
            continue
        m = parse_member(item)
        m["label"] = m["provider"] + (f"-{m['model']}" if m["model"] else "")
        members.append(m)
    return members


# --------------------------------------------------------------------------- #
# argv / env rendering
# --------------------------------------------------------------------------- #

def render_call(p: dict, model: str, system: str | None, web: bool,
                settings: dict, outfile: str, stream: bool = False,
                agentfile: str = "") -> tuple:
    """Return (argv, env_overrides) for one provider call, applying Fusion knobs.
    When stream=True and the provider declares a `stream` cap, request the CLI's
    realtime/streaming output format instead of buffered JSON (used only for the
    final synthesis call, so the answer can type itself out token-by-token).
    `agentfile` is the path to a provider-generated agent file (e.g. kimi's
    read-only tool policy); it's rendered as `--agent-file <path>` when the
    provider declares an `agent_file` record."""
    argv = list(p["cmd"])
    env_over: dict = {}
    caps = p.get("caps", {})

    if model and p.get("model_flag"):
        argv += [p["model_flag"], model]
    if stream and (p.get("stream") or {}).get("args"):
        argv += list(p["stream"]["args"])
    elif p.get("capture") == "json" and p.get("json_output_flag"):
        argv += list(p["json_output_flag"])
    if system and p.get("system_flag"):
        argv += [p["system_flag"], system]

    # Web tools (Fusion: on for panel + judge, off for synthesis).
    if web:
        argv += list(caps.get("web_on", []))
        argv += list(caps.get("mutator_disallow", []))
    else:
        argv += list(caps.get("web_off", []))

    # Tool-call cap only matters while tools can run.
    mtc = settings.get("max_tool_calls")
    if web and mtc and caps.get("tool_cap"):
        argv += [t.replace("{max_tool_calls}", str(mtc)) for t in caps["tool_cap"]]

    eff = settings.get("effort")
    if eff and caps.get("effort"):
        argv += [t.replace("{effort}", str(eff)) for t in caps["effort"]]

    mot = settings.get("max_output_tokens")
    if mot and caps.get("max_tokens_env"):
        env_over[caps["max_tokens_env"]] = str(mot)

    # Agent file (kimi): a generated read-only tool policy with web on/off baked in.
    af = p.get("agent_file")
    if af and agentfile:
        argv += [af.get("flag", "--agent-file"), agentfile]

    if p.get("capture") == "outfile":
        argv += [p.get("outfile_flag", "-o"), outfile]
    if p.get("stdin_arg"):
        argv += [p["stdin_arg"]]
    return argv, env_over


def append_prompt_arg(argv: list, p: dict, text: str) -> list:
    """Some CLIs take the prompt as a command-line argument, not on stdin
    (provider `prompt: "arg"`, e.g. antigravity's `agy -p "<prompt>"`). Append
    [prompt_flag, text] (or a bare positional if no prompt_flag is set)."""
    pf = p.get("prompt_flag")
    return argv + ([pf, text] if pf else [text])


def extract_json_result(text: str, result_path: str) -> str:
    text = text.strip()
    try:
        v = json.loads(text)
    except ValueError:
        return text
    if isinstance(v, dict):
        val = v.get(result_path)
        if isinstance(val, str):
            return val.strip()
        for k in ("result", "response", "text", "content", "output_text"):
            if isinstance(v.get(k), str):
                return v[k].strip()
    return text


def tolerant_json(s: str) -> dict | None:
    if not s:
        return None
    s = s.strip()
    if s.startswith("```"):
        s = re.sub(r"^```[a-zA-Z0-9]*\s*", "", s)
        s = re.sub(r"\s*```$", "", s.strip())
    for candidate in (s, _slice_braces(s)):
        if not candidate:
            continue
        try:
            v = json.loads(candidate)
            if isinstance(v, dict):
                return v
        except ValueError:
            continue
    return None


def _slice_braces(s: str) -> str | None:
    a, b = s.find("{"), s.rfind("}")
    return s[a:b + 1] if (a != -1 and b > a) else None


def render_agent_file(af: dict, web: bool) -> str:
    """Build a minimal Kimi agent file (YAML) that inherits the built-in `default`
    agent but excludes the mutating tools (read-only, like scry's other panels) and
    — when web is off — the web tools too. This is how scry renders Fusion's web
    on/off and the read-only invariant for kimi, which has no argv flags for either.
    Hand-written YAML (no PyYAML dependency); every value is a fixed constant."""
    excl = list(af.get("exclude_always", []))
    if not web:
        excl += list(af.get("exclude_web_off", []))
    lines = ["version: 1", "agent:", f"  extend: {af.get('extend', 'default')}"]
    if excl:
        lines.append("  exclude_tools:")
        lines += [f'    - "{t}"' for t in excl]
    return "\n".join(lines) + "\n"


def _dig(obj, dotted: str):
    """Walk a dotted path (e.g. 'usage.server_tool_use.web_search_requests')
    through nested dicts; return the leaf value or None if any hop is missing."""
    cur = obj
    for key in dotted.split("."):
        if not isinstance(cur, dict):
            return None
        cur = cur.get(key)
    return cur


def extract_usage(obj, p: dict) -> dict:
    """Pull cost/token numbers from a provider's parsed JSON output using its
    config-driven `usage` path map. Returns {} when the provider declares no
    `usage` block or the object isn't a dict — so non-metered CLIs report nothing
    rather than guessing."""
    spec = p.get("usage")
    if not isinstance(spec, dict) or not isinstance(obj, dict):
        return {}
    meta = {}
    for field, path in spec.items():
        if field.startswith("_") or not isinstance(path, str):
            continue
        val = _dig(obj, path)
        if isinstance(val, (int, float)) and not isinstance(val, bool):
            meta[field] = val
    return meta


def summarize_cost(meters: list, elapsed: float) -> dict:
    """Roll per-stage usage records up into the run's `cost` block. total_usd is
    None when no stage reported a cost (e.g. a panel of only non-metered CLIs),
    so we never imply $0 when we simply don't know."""
    total, have_cost = 0.0, False
    in_tok = out_tok = web = 0
    for m in meters:
        c = m.get("cost_usd")
        if isinstance(c, (int, float)) and not isinstance(c, bool):
            total += c
            have_cost = True
        in_tok += sum(m.get(k) or 0 for k in
                      ("input_tokens", "cache_creation_tokens", "cache_read_tokens"))
        out_tok += m.get("output_tokens") or 0
        web += m.get("web_searches") or 0
    metered = sum(1 for m in meters
                  if isinstance(m.get("cost_usd"), (int, float))
                  and not isinstance(m.get("cost_usd"), bool))
    return {
        "total_usd": round(total, 4) if have_cost else None,
        "calls": len(meters),
        "metered_calls": metered,
        "input_tokens": in_tok or None,
        "output_tokens": out_tok or None,
        "web_searches": web or None,
        "seconds": round(elapsed, 1),
        "by_stage": meters,
    }


def _ktok(n) -> str:
    if not n:
        return "0"
    if n >= 10000:
        return f"{round(n / 1000)}k"
    if n >= 1000:
        return f"{n / 1000:.1f}k"
    return str(int(n))


def format_cost_tally(cost: dict, color: bool) -> str:
    """One-line run footer: calls · $ · tokens · web · seconds, honest about
    which calls were actually metered."""
    parts = [f"{cost.get('calls', 0)} calls"]
    if cost.get("total_usd") is not None:
        parts.append(f"${cost['total_usd']:.2f}")
    it, ot = cost.get("input_tokens"), cost.get("output_tokens")
    if it or ot:
        parts.append(f"{_ktok(it)}→{_ktok(ot)} tok")
    if cost.get("web_searches"):
        parts.append(f"{cost['web_searches']} web")
    parts.append(f"{cost.get('seconds', 0):.0f}s")
    line = "✦ " + " · ".join(parts)
    metered, calls = cost.get("metered_calls", 0), cost.get("calls", 0)
    if cost.get("total_usd") is None:
        line += "  (no per-call cost reported by these providers)"
    elif metered < calls:
        line += f"  ($ from {metered}/{calls} metered calls; subscription CLIs report none)"
    return f"\x1b[2m{line}\x1b[0m" if color else line


