#!/usr/bin/env python3
"""scry-deepseek — minimal headless adapter for DeepSeek's OpenAI-compatible API.

scry is built to drive *subscription* CLIs (claude/codex/agy) with no API keys.
DeepSeek has no subscription CLI — only its API — so this shim lets scry treat
DeepSeek as a provider for TESTING / benchmark recreation (e.g. OpenRouter's
budget-panel DRACO result). It is the ONE provider that needs an API key:
set DEEPSEEK_API_KEY. See README ("DeepSeek — the API-key exception").

scry calls it like any text provider:
    echo "<prompt>" | scry-deepseek --model deepseek-chat [--system "<sys>"]
It reads the prompt on stdin and prints the assistant message to stdout.
Errors go to stderr with a non-zero exit (HTTP status in the message, so scry's
retry/backoff sees "429"/"rate"/etc.). Standard library only.

Note: the raw chat API has NO web search, so this DeepSeek member answers from
model knowledge only — a handicap on web-research tasks like DRACO.
"""
import argparse
import json
import os
import sys
import urllib.error
import urllib.request


# DeepSeek's chat API silently defaults max_tokens to 4096, truncating long
# answers. We instead request the chosen model's documented maximum output so
# nothing is cut off — a ceiling is free (the model stops when done).
DEEPSEEK_MAX_OUTPUT = {
    "deepseek-v4-pro": 384000,     # V4 family: 1M context, 384K max output
    "deepseek-chat": 8192,         # legacy alias -> V4-Flash (non-thinking)
    "deepseek-reasoner": 8192,     # legacy alias -> V4-Flash (thinking)
}
DEFAULT_MAX_OUTPUT = 8192          # safe documented ceiling for unknown ids


def resolve_max_tokens(explicit, model):
    """Output-token ceiling to request: an explicit --max-tokens if given, else
    the model's documented maximum (never the API's silent 4096 default)."""
    if explicit:
        return explicit
    return DEEPSEEK_MAX_OUTPUT.get(model, DEFAULT_MAX_OUTPUT)


def _load_env_file() -> None:
    """Load KEY=VALUE lines from a `.env` next to this script into the process
    environment, WITHOUT overriding variables already set (so an explicit
    `export` or a CI secret always wins). Looked up by this script's own path,
    not cwd, since scry runs providers from a throwaway temp dir. Keeps scry
    zero-dependency — no python-dotenv. When the key lives only in `.env`, it
    never enters scry's other subprocesses (claude/codex/agy) — only this one."""
    path = os.path.join(os.path.dirname(os.path.abspath(__file__)), ".env")
    try:
        with open(path) as f:
            lines = f.readlines()
    except OSError:
        return
    for raw in lines:
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if key and key not in os.environ:
            os.environ[key] = val


def main() -> int:
    _load_env_file()
    ap = argparse.ArgumentParser(prog="scry-deepseek", add_help=True)
    ap.add_argument("--model", default="deepseek-chat",
                    help="DeepSeek model id (e.g. deepseek-chat, deepseek-reasoner)")
    ap.add_argument("--system", default=None, help="optional system prompt")
    ap.add_argument("--timeout", type=float, default=300.0)
    ap.add_argument("--max-tokens", type=int, default=None)
    ap.add_argument("--base-url", default=os.environ.get("DEEPSEEK_BASE_URL",
                                                          "https://api.deepseek.com"),
                    help="API base (default https://api.deepseek.com or $DEEPSEEK_BASE_URL)")
    args = ap.parse_args()

    key = os.environ.get("DEEPSEEK_API_KEY")
    if not key:
        sys.stderr.write("scry-deepseek: DEEPSEEK_API_KEY not set (this provider needs an "
                         "API key — see README 'DeepSeek — the API-key exception')\n")
        return 2

    prompt = sys.stdin.read()
    if not prompt.strip():
        sys.stderr.write("scry-deepseek: empty prompt on stdin\n")
        return 2

    messages = []
    if args.system:
        messages.append({"role": "system", "content": args.system})
    messages.append({"role": "user", "content": prompt})
    payload = {"model": args.model, "messages": messages, "stream": False,
               "max_tokens": resolve_max_tokens(args.max_tokens, args.model)}

    url = args.base_url.rstrip("/") + "/chat/completions"
    req = urllib.request.Request(
        url, data=json.dumps(payload).encode(), method="POST",
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})

    try:
        with urllib.request.urlopen(req, timeout=args.timeout) as resp:
            body = json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        detail = ""
        try:
            detail = e.read().decode(errors="replace")[:400]
        except Exception:  # noqa: BLE001
            pass
        # Include the status code so scry's transient-error retry can match (429/5xx).
        sys.stderr.write(f"scry-deepseek: HTTP {e.code} {e.reason}: {detail}\n")
        return 1
    except urllib.error.URLError as e:
        sys.stderr.write(f"scry-deepseek: connection error: {e.reason}\n")
        return 1
    except Exception as e:  # noqa: BLE001
        sys.stderr.write(f"scry-deepseek: {e}\n")
        return 1

    try:
        text = body["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError):
        sys.stderr.write(f"scry-deepseek: unexpected response: {json.dumps(body)[:400]}\n")
        return 1

    if not text:
        sys.stderr.write("scry-deepseek: empty completion\n")
        return 1
    sys.stdout.write(text)
    return 0


if __name__ == "__main__":
    sys.exit(main())
