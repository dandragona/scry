# Eval driver
# --------------------------------------------------------------------------- #

async def eval_subjective(mod, cfg, scry_path, items, extra_args, concurrency):
    settings = dict(cfg.get("settings", {}))
    sem = asyncio.Semaphore(concurrency)   # created on the running loop (3.9 binds here)
    label2prov = {m.get("label", m["provider"]): m["provider"] for m in cfg.get("panel", [])}
    fused_family = FAMILY.get(cfg.get("aggregator", {}).get("provider", "claude"), "anthropic")
    cwd = tempfile.mkdtemp(prefix="scry-eval-")
    results = []
    judge_calls = 0
    try:
        for it in items:
            print(f"  · subjective[{it['id']}] running scry…", file=sys.stderr, flush=True)
            data = run_scry(scry_path, it["prompt"], extra_args)
            if data.get("status") != "ok":
                print(f"    ! SUT failed: {data.get('error') or data.get('failure_reason')}",
                      file=sys.stderr)
                results.append({"id": it["id"], "sut_ok": False,
                                "error": data.get("error") or data.get("failure_reason")})
                continue
            fused = data["final"]
            solos = [r for r in data["responses"] if r["ok"] and r.get("content")]
            matchups = []
            for r in solos:
                solo_fam = FAMILY.get(label2prov.get(r["model"], ""), "?")
                judges, jf = judges_for(fused_family, solo_fam)
                if not judges:
                    continue
                print(f"    judging fused vs {r['model']} "
                      f"(judges: {', '.join(jf)})…", file=sys.stderr, flush=True)
                score, n = await judge_matchup(mod, cfg, settings, cwd, sem,
                                               it["prompt"], fused, r["content"], judges)
                judge_calls += n
                matchups.append({"opponent": r["model"], "judge_families": jf,
                                 "fused_score": score, "n_votes": n})
            scored = [m for m in matchups if m["fused_score"] is not None]
            field = (sum(m["fused_score"] for m in scored) / len(scored)) if scored else None
            toughest = min(scored, key=lambda m: m["fused_score"]) if scored else None
            results.append({
                "id": it["id"], "sut_ok": True, "scry_seconds": data.get("_seconds"),
                "matchups": matchups,
                "fused_winrate_vs_field": field,
                "vs_toughest": toughest,
            })
    finally:
        import shutil
        shutil.rmtree(cwd, ignore_errors=True)
    return results, judge_calls


def eval_objective(scry_path, items, extra_args):
    results = []
    for it in items:
        print(f"  · objective[{it['id']}] running scry…", file=sys.stderr, flush=True)
        data = run_scry(scry_path, it["prompt"], extra_args)
        if data.get("status") != "ok":
            print(f"    ! SUT failed: {data.get('error') or data.get('failure_reason')}",
                  file=sys.stderr)
            results.append({"id": it["id"], "sut_ok": False,
                            "error": data.get("error") or data.get("failure_reason")})
            continue
        per_solo = {}
        for r in data["responses"]:
            if not r["ok"]:
                per_solo[r["model"]] = {"correct": None, "evidence": "(failed)"}
                continue
            ok, ev, tok = grade_objective(r["content"], it["expected"])
            per_solo[r["model"]] = {"correct": ok, "evidence": ev, "matched": tok}
        f_ok, f_ev, f_tok = grade_objective(data["final"], it["expected"])
        results.append({
            "id": it["id"], "sut_ok": True, "scry_seconds": data.get("_seconds"),
            "expected": it["expected"],
            "solos": per_solo,
            "fused": {"correct": f_ok, "evidence": f_ev, "matched": f_tok},
            "any_solo_correct": any(v["correct"] for v in per_solo.values()),
        })
    return results


