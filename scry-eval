# Model family per provider. Used for family-neutral judge selection.
FAMILY = {"claude": "anthropic", "codex": "openai", "agy": "google"}
# Canonical judge per family (a strong model from each).
FAMILY_JUDGE = {
    "anthropic": {"provider": "claude", "model": "opus"},
    "openai":    {"provider": "codex",  "model": ""},
    "google":    {"provider": "agy",    "model": "Gemini 3.1 Pro (High)"},
}

JUDGE_SYSTEM = (
    "You are a blind, impartial evaluator. You are shown a user prompt and two "
    "candidate answers labelled A and B. Decide which answer better satisfies the "
    "prompt, judging ONLY on correctness, completeness, and relevance — ignore "
    "length, formatting, and writing style, and do not assume either label is "
    "better. If they are genuinely equal, call it a tie. Respond with EXACTLY one "
    "line and nothing else: 'VERDICT: A', 'VERDICT: B', or 'VERDICT: TIE'."
)


# --------------------------------------------------------------------------- #
# Load scry as a module to reuse its provider plumbing (load_config, call_cli).
# --------------------------------------------------------------------------- #

def load_scry_module(scry_path: Path):
    # scry has no .py extension, so give spec_from_file_location an explicit loader.
    from importlib.machinery import SourceFileLoader
    loader = SourceFileLoader("scry_sut", str(scry_path))
    spec = importlib.util.spec_from_loader("scry_sut", loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)                 # defines symbols; main() not called (name != __main__)
    return mod


# --------------------------------------------------------------------------- #
# System under test: run the real ./scry --json
# --------------------------------------------------------------------------- #

def run_scry(scry_path: Path, prompt: str, extra_args, timeout: float = 900.0) -> dict:
    """Return parsed `scry --json` output, or a {'status':'sut_error',...} dict."""
    argv = [str(scry_path), "--json", *extra_args, prompt]
    t0 = time.time()
    try:
        proc = subprocess.run(argv, capture_output=True, text=True, timeout=timeout)
    except subprocess.TimeoutExpired:
        return {"status": "sut_error", "error": f"scry timed out after {int(timeout)}s"}
    dt = time.time() - t0
    raw = (proc.stdout or "").strip()
    try:
        data = json.loads(raw)
    except ValueError:
        return {"status": "sut_error",
                "error": f"non-JSON scry output (exit {proc.returncode}): "
                         f"{(proc.stderr or raw)[:300]}"}
    data["_seconds"] = round(dt, 1)
    return data


# --------------------------------------------------------------------------- #
# Objective grading (code only)
# --------------------------------------------------------------------------- #

def find_answer_line(text: str):
    if not text:
        return None
    hits = re.findall(r"(?im)^\s*answer\s*[:=]\s*(.+?)\s*$", text)
    return hits[-1].strip() if hits else None


def token_match(hay: str, token: str) -> bool:
    """Match `token` in `hay` with light boundaries so '20' doesn't match '120'
    and '9.9' doesn't match '19.9' — but phrases like '5 cents.' still match."""
    pat = r"(?<![\w.])" + re.escape(token.strip()) + r"(?![\w])"
    return re.search(pat, hay, re.IGNORECASE) is not None


def grade_objective(text: str, expected):
    """Return (correct, evidence, matched_token). Prefer the ANSWER: line; fall
    back to full text (logged) when the synthesizer dropped the format."""
    line = find_answer_line(text or "")
    hay = line if line is not None else (text or "")
    for tok in expected:
        if token_match(hay, tok):
            return True, (line if line is not None else "(full text)"), tok
    return False, (line if line is not None else "(full text)"), None


# --------------------------------------------------------------------------- #
# Subjective judging (blind, order-swapped, family-neutral)
# --------------------------------------------------------------------------- #

def parse_verdict(text: str):
    if not text:
        return None
    hits = re.findall(r"(?i)verdict\s*[:\-]?\s*(a|b|tie)\b", text)
    return hits[-1].upper() if hits else None


async def judge_once(mod, cfg, settings, judge, cwd, prompt, ans_a, ans_b):
    juser = (f"User prompt:\n{prompt}\n\n"
             f"Response A:\n{ans_a}\n\nResponse B:\n{ans_b}\n\n"
             "Which response better answers the prompt? Reply with one line only.")
    try:
        out = await mod.call_cli(cfg, judge["provider"], judge.get("model", ""),
                                 JUDGE_SYSTEM, juser, cwd, 0, False, settings)
    except Exception as e:  # noqa: BLE001 — a flaky judge call must not abort the eval
        return None, str(e)
    return parse_verdict(out), None


async def judge_matchup(mod, cfg, settings, cwd, sem, prompt, fused, solo,
                        judges):
    """Judge fused-vs-solo. For each judge, both orderings. fused gets
    win=1/tie=0.5/loss=0; matchup score = mean over judges & valid orderings."""
    async def one(judge, fused_is_a):
        async with sem:
            a, b = (fused, solo) if fused_is_a else (solo, fused)
            v, err = await judge_once(mod, cfg, settings, judge, cwd, prompt, a, b)
            if v is None:
                return None
            if v == "TIE":
                return 0.5
            fused_label = "A" if fused_is_a else "B"
            return 1.0 if v == fused_label else 0.0

    tasks = []
    for j in judges:
        tasks.append(one(j, True))
        tasks.append(one(j, False))
    scores = [s for s in await asyncio.gather(*tasks) if s is not None]
    return (sum(scores) / len(scores)) if scores else None, len(scores)


def judges_for(fused_family: str, solo_family: str):
    fams = [f for f in FAMILY_JUDGE if f not in (fused_family, solo_family)]
    return [FAMILY_JUDGE[f] for f in fams], fams


# --------------------------------------------------------------------------- #
# DRACO regime — Perplexity's deep-research benchmark (the one OpenRouter Fusion
# headlines). Each task ships a weighted rubric (~39 criteria across 4 axes).
# We grade fused + each solo against the rubric using the OFFICIAL per-criterion
# MET/UNMET method and normalization from the MIT `rubric` scorer
# (github.com/The-LLM-Data-Company/rubric), driven by a subscription-CLI grader.
# This measures OUR scry on DRACO's 0–100 scale; it does NOT reproduce
# OpenRouter's headline (different model builds / Exa retrieval / judge). See README.
# --------------------------------------------------------------------------- #

# Verbatim system prompt from rubric/autograders/per_criterion_grader.py
# (DEFAULT_SYSTEM_PROMPT) so MET/UNMET semantics match the official scorer exactly.
DRACO_GRADER_SYSTEM = """You are evaluating a response for a given query against a single criterion.

You will receive the response to evaluate, a single criterion to check, and a <criterion_type> field indicating if the criterion is positive or negative.

CRITERION TYPES:
The <criterion_type> field tells you whether this criterion describes something desirable (positive) or undesirable (negative). Your job is THE SAME for both types: determine if the thing described in the criterion is actually present in the response.

POSITIVE CRITERIA:
Positive criteria describe desired traits, requirements, or content that should be present.
- MET (criterion_status: "MET"): The response contains/satisfies the requirement
- UNMET (criterion_status: "UNMET"): The response does not contain/satisfy the requirement

NEGATIVE CRITERIA:
Negative criteria describe active errors or mistakes that the response is making.
- MET (criterion_status: "MET"): The response advocates, states, or recommends the problematic thing
- UNMET (criterion_status: "UNMET"): The response does NOT make this error, OR it mentions the thing only to warn against it or mention why it's wrong

Examples of what does NOT count as MET for negative criteria:
- "This is often misdiagnosed as X, but it's actually Y" -> NOT stating it's X (UNMET)
- "Avoid doing X because..." -> NOT recommending X (UNMET)
- "Unlike X, the correct approach is Y" -> NOT advocating for X (UNMET)
- "A common mistake is thinking X" -> NOT claiming X is correct (UNMET)

EVALUATION RULES:
- For numerical values: Check if they fall within specified ranges or match exactly as required.
- For factual claims: Verify the information is present and accurate, regardless of exact phrasing.
- For required elements: Confirm presence, counting precisely when numbers are specified.
- For exclusion requirements: Confirm that restricted content is absent.
- For length requirements: Carefully measure the number of words, characters, items, etc.
- Be strict about factual accuracy but flexible about wording.
- Accept semantically equivalent statements or implications where appropriate.
- Pay careful attention to negation, warnings, and contrasts.

CONDITIONAL VS UNCONDITIONAL ACTIONS (CRITICAL):
When a criterion requires an action to be done "immediately", "now", "as soon as possible", or unconditionally, you must distinguish:
- UNCONDITIONAL: "Give epinephrine now" or "Administer X immediately" -> action IS being taken
- CONDITIONAL: "If Y occurs, give epinephrine" or "Start X if condition Z" -> action is NOT being taken immediately; it's contingent on a future condition

If the criterion says something should happen "immediately" or without conditions, a conditional statement does NOT satisfy the criterion. Mark as UNMET.

Example:
- Criterion: "Administers alteplase immediately for acute ischemic stroke"
- Output: "If CT confirms no hemorrhage, consider alteplase" -> UNMET (conditional, not immediate)
- Output: "Give alteplase now per acute stroke protocol" -> MET (immediate, unconditional)

IMPLICIT VS EXPLICIT SATISFACTION:
Consider whether a criterion can be satisfied implicitly through context, tone, or logical implication, not just explicit statements:
- "States there is no location in China" can be MET by "Locations are only in United States and Canada"-if locations are ONLY in US and Canada, China is excluded; no need to mention China
- "Confirms the user is logged out" can be MET by "Session expired at 3:42 PM"-an expired session means the user is logged out, even without stating it directly

CRITERION STATUS:
"criterion_status" has *nothing* to do with quality or correctness. It only means:
- "MET": The thing described in the criterion IS present/occurring in the response
- "UNMET": The thing described in the criterion IS NOT present/occurring in the response

Your response must be valid JSON with this exact format:

{
"explanation": "Brief explanation of why the criterion is MET.",
"criterion_status": "MET"
}

Return only raw JSON starting with {, no back-ticks, no 'json' prefix."""


def parse_criterion_verdict(text: str):
    """Extract MET/UNMET from a grader reply (prefer the JSON field, then fall back)."""
    if not text:
        return None
    t = text.strip()
    t2 = re.sub(r"^```[a-zA-Z0-9]*\s*", "", t)
    t2 = re.sub(r"\s*```$", "", t2.strip())
    for cand in (t2, t):
        try:
            o = json.loads(cand)
            if isinstance(o, dict):
                v = o.get("criterion_status")
                if isinstance(v, str) and v.upper() in ("MET", "UNMET"):
                    return v.upper()
        except ValueError:
            pass
    m = re.search(r'criterion_status"?\s*[:=]\s*"?\s*(MET|UNMET)', text, re.IGNORECASE)
    if m:
        return m.group(1).upper()
    toks = re.findall(r"\b(UNMET|MET)\b", text, re.IGNORECASE)  # UNMET checked first
    return toks[-1].upper() if toks else None


def draco_aggregate(reports):
    """Official normalization from rubric/autograders/per_criterion_grader.py.
    reports: list of (verdict, weight); verdict in {'MET','UNMET',None}. None
    (failed grade) counts as not-MET, and is also reported as `ungraded`."""
    pos = sum(max(0.0, w) for _, w in reports)
    neg = sum(abs(w) for v, w in reports if w < 0)
    wsum = sum((1.0 if v == "MET" else 0.0) * w for v, w in reports)
    if pos > 0:
        score = max(0.0, min(1.0, wsum / pos))
    elif neg > 0:                       # all-negative rubric: start at 1.0, errors subtract
        score = max(0.0, min(1.0, 1.0 + wsum / neg))
    else:
        score = 0.0
    graded = sum(1 for v, _ in reports if v is not None)
    return {"score": round(score * 100, 2), "raw": round(wsum, 2),
            "graded": graded, "ungraded": len(reports) - graded,
            "met": sum(1 for v, _ in reports if v == "MET"), "total": len(reports)}


def load_draco(path, n_tasks=0, stratified=False, criteria_limit=0):
    rows = [json.loads(line) for line in Path(path).read_text().splitlines() if line.strip()]
    items = []
    for r in rows:
        ans = json.loads(r["answer"]) if isinstance(r["answer"], str) else r["answer"]
        crit = []
        for s in ans.get("sections", []):
            for c in s.get("criteria", []):
                crit.append({"weight": float(c["weight"]), "requirement": c["requirement"],
                             "section": s.get("id")})
        if criteria_limit:
            crit = crit[:criteria_limit]
        items.append({"id": r["id"], "domain": r.get("domain", ""),
                      "problem": r["problem"], "criteria": crit})
    if stratified:                      # one task per domain (max coverage at min cost)
        seen, strat = set(), []
        for it in items:
            if it["domain"] not in seen:
                seen.add(it["domain"])
                strat.append(it)
        items = strat
    return items[:n_tasks] if n_tasks else items


TRANSIENT_HINTS = ("rate", "429", "overload", "quota", "limit", "timeout",
                   "throttl", "503", "502", "unavailable", "exhausted")


def is_transient(msg: str) -> bool:
    m = (msg or "").lower()
    return any(h in m for h in TRANSIENT_HINTS)


async def call_with_retry(make_coro, attempts=4, base_delay=5.0):
    """Await make_coro(); on transient (rate-limit-ish) errors retry with
    exponential backoff (5s, 15s, 45s). Re-raise non-transient errors at once."""
    last = None
    for i in range(attempts):
        try:
            return await make_coro()
        except Exception as e:  # noqa: BLE001
            last = e
            if i == attempts - 1 or not is_transient(str(e)):
                raise
            await asyncio.sleep(base_delay * (3 ** i))
    raise last  # unreachable


async def grade_against_rubric(mod, cfg, settings, grader, cwd, sem, query, to_grade, criteria):
    """Grade one text against all criteria (one CLI call each, in parallel).
    Each call retries on transient/rate-limit errors; a still-failing criterion
    degrades to None (counted UNMET + reported as ungraded) rather than aborting."""
    async def one(c):
        async with sem:
            ctype = "negative" if c["weight"] < 0 else "positive"
            user = (f"<criterion_type>\n{ctype}\n</criterion_type>\n\n"
                    f"<criterion>\n{c['requirement']}\n</criterion>\n\n"
                    f"<query>{query}</query>\n\n"
                    f"<response>\n{to_grade}\n</response>")
            try:
                out = await call_with_retry(lambda: mod.call_cli(
                    cfg, grader["provider"], grader.get("model", ""),
                    DRACO_GRADER_SYSTEM, user, cwd, 0, False, settings))
            except Exception:  # noqa: BLE001 — exhausted/non-transient -> ungraded
                return (None, c["weight"])
            return (parse_criterion_verdict(out), c["weight"])
    return list(await asyncio.gather(*(one(c) for c in criteria)))


