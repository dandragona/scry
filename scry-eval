def parse_oneshot(text):
    """Parse {criteria_evaluations:[{criterion_idx,criterion_status,...}]} -> {idx: verdict}."""
    if not text:
        return None
    t = text.strip()
    t = re.sub(r"^```[a-zA-Z0-9]*\s*", "", t)
    t = re.sub(r"\s*```$", "", t.strip())
    obj = None
    try:
        obj = json.loads(t)
    except ValueError:
        a, b = t.find("{"), t.rfind("}")
        if a != -1 and b > a:
            try:
                obj = json.loads(t[a:b + 1])
            except ValueError:
                obj = None
    if not isinstance(obj, dict) or not isinstance(obj.get("criteria_evaluations"), list):
        return None
    m = {}
    for e in obj["criteria_evaluations"]:
        if isinstance(e, dict) and isinstance(e.get("criterion_idx"), int):
            st = e.get("criterion_status")
            if isinstance(st, str) and st.upper() in ("MET", "UNMET"):
                m[e["criterion_idx"]] = st.upper()
    return m


async def grade_oneshot(mod, cfg, settings, grader, cwd, query, to_grade, criteria):
    """Grade all criteria in ONE call. Missing criteria -> UNMET (official). A failed
    or badly-truncated call -> all None (ungraded), so the task is flagged incomplete."""
    lines = []
    for i, c in enumerate(criteria):
        ctype = ("NEGATIVE (status MET if error IS present, UNMET if error is NOT present)"
                 if c["weight"] < 0 else
                 "POSITIVE (status MET if requirement IS present, UNMET if requirement is NOT present)")
        lines.append(f"{i}. [{ctype}] (weight: {c['weight']}) {c['requirement']}")
    user = ("Evaluate the response against the following criteria:\n<criteria>\n"
            + "\n".join(lines) + "\n</criteria>\n\n"
            f"<query>{query}</query>\n\n"
            f"<response>\n{to_grade}\n</response>\n\n"
            "Provide your evaluation as JSON only.")
    try:
        out = await call_with_retry(lambda: mod.call_cli(
            cfg, grader["provider"], grader.get("model", ""),
            DRACO_ONESHOT_SYSTEM, user, cwd, 0, False, settings))
    except Exception:  # noqa: BLE001
        return [(None, c["weight"]) for c in criteria]
    emap = parse_oneshot(out)
    if not emap or len(emap) < max(1, len(criteria) // 2):   # garbage/truncated -> ungraded
        return [(None, c["weight"]) for c in criteria]
    return [(emap.get(i, "UNMET"), c["weight"]) for i, c in enumerate(criteria)]


async def grade_output(mode, mod, cfg, settings, grader, cwd, sem, query, to_grade, criteria):
    """Dispatch to the chosen grading mode; return (reports, n_calls)."""
    if mode == "one-shot":
        return await grade_oneshot(mod, cfg, settings, grader, cwd, query, to_grade, criteria), 1
    reps = await grade_against_rubric(mod, cfg, settings, grader, cwd, sem,
                                      query, to_grade, criteria)
    return reps, len(criteria)


def task_complete(r) -> bool:
    """A task is done (skippable on resume) only if its fused answer was actually
    graded — i.e. the grader call succeeded (ungraded == 0). A throttled task whose
    grading failed has ungraded > 0 and will be re-run on resume."""
    return bool(r.get("sut_ok")) and r.get("fused", {}).get("ungraded", 1) == 0


async def eval_draco(mod, cfg, scry_path, items, extra_args, grader, concurrency,
                     grade_solos, grader_mode="one-shot", initial_results=None, save_cb=None):
    """Run DRACO over `items`, checkpointing after every task via save_cb so a
    rate-limit/quota death loses at most the in-flight task (resume re-runs it)."""
    settings = dict(cfg.get("settings", {}))
    sem = asyncio.Semaphore(concurrency)   # created on the running loop (3.9 binds here)
    cwd = tempfile.mkdtemp(prefix="scry-draco-")
    results = list(initial_results or [])
    grade_calls = 0
    try:
        for it in items:
            try:
                crit = it["criteria"]
                print(f"  · draco[{it['id'][:8]}] {it['domain']} ({len(crit)} criteria) — running scry…",
                      file=sys.stderr, flush=True)
                data = run_scry(scry_path, it["problem"], extra_args)
                if data.get("status") != "ok":
                    print("    ! SUT failed (will retry on resume)", file=sys.stderr)
                    results.append({"id": it["id"], "domain": it["domain"], "sut_ok": False,
                                    "error": data.get("error") or data.get("failure_reason")})
                    continue
                print(f"    grading FUSED ({len(crit)} criteria, {grader_mode})…",
                      file=sys.stderr, flush=True)
                freps, nc = await grade_output(grader_mode, mod, cfg, settings, grader, cwd, sem,
                                               it["problem"], data["final"], crit)
                grade_calls += nc
                fused_eval = draco_aggregate(freps)
                solo_evals = {}
                if grade_solos:
                    for r in data["responses"]:
                        if not (r["ok"] and r.get("content")):
                            solo_evals[r["model"]] = {"score": None}
                            continue
                        print(f"    grading solo {r['model']}…", file=sys.stderr, flush=True)
                        sreps, nc = await grade_output(grader_mode, mod, cfg, settings, grader, cwd,
                                                       sem, it["problem"], r["content"], crit)
                        grade_calls += nc
                        solo_evals[r["model"]] = draco_aggregate(sreps)
                best = max((e["score"] for e in solo_evals.values()
                            if e.get("score") is not None), default=None)
                print(f"    → fused {fused_eval['score']:.1f}"
                      + (f"  best-solo {best:.1f}" if best is not None else "")
                      + f"  (graded {fused_eval['graded']}/{fused_eval['total']})",
                      file=sys.stderr, flush=True)
                results.append({"id": it["id"], "domain": it["domain"], "sut_ok": True,
                                "scry_seconds": data.get("_seconds"), "n_criteria": len(crit),
                                "fused": fused_eval, "solos": solo_evals})
            except Exception as e:  # noqa: BLE001 — one bad task must not lose the run
                print(f"    ! task error ({e}); recorded, continuing", file=sys.stderr)
                results.append({"id": it["id"], "domain": it.get("domain", ""),
                                "sut_ok": False, "error": f"task exception: {e}"})
            if save_cb:
                save_cb(results, grade_calls)   # atomic checkpoint after every task
    finally:
        import shutil
        shutil.rmtree(cwd, ignore_errors=True)
    return results, grade_calls


