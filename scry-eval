def _mark(v):
    return {True: "✓", False: "✗", None: "—"}[v]


def report(obj_results, subj_results, model_names):
    print("\n" + "=" * 72)
    print("OBJECTIVE  (ground-truth accuracy — no LLM judge)")
    print("=" * 72)
    if obj_results:
        cols = model_names + ["FUSED"]
        header = "item".ljust(18) + "".join(c[:12].ljust(13) for c in cols)
        print(header)
        tally = {c: [0, 0] for c in cols}  # [correct, graded]
        for r in obj_results:
            if not r.get("sut_ok"):
                print(r["id"].ljust(18) + "SUT FAILED")
                continue
            row = r["id"].ljust(18)
            for m in model_names:
                c = r["solos"].get(m, {}).get("correct")
                row += _mark(c).ljust(13)
                if c is not None:
                    tally[m][1] += 1
                    tally[m][0] += int(c)
            fc = r["fused"]["correct"]
            row += _mark(fc).ljust(13)
            tally["FUSED"][1] += 1
            tally["FUSED"][0] += int(fc)
            print(row)
        print("-" * len(header))
        acc_row = "accuracy".ljust(18)
        for c in cols:
            got, n = tally[c]
            acc_row += (f"{got}/{n}" if n else "—").ljust(13)
        print(acc_row)
        # The comparison that matters: fused vs the best single model.
        best_model, best_acc = None, -1.0
        for m in model_names:
            got, n = tally[m]
            if n and got / n > best_acc:
                best_model, best_acc = m, got / n
        fgot, fn = tally["FUSED"]
        if best_model and fn:
            facc = fgot / fn
            verdict = ("fused ≥ best single" if facc >= best_acc
                       else "fused WORSE than best single")
            print(f"\n  best single model: {best_model} ({best_acc:.0%})   "
                  f"fused: {facc:.0%}   →  {verdict}")

    print("\n" + "=" * 72)
    print("SUBJECTIVE  (blind, order-swapped, family-neutral judges)")
    print("  fused score per matchup: 1=fused wins, 0.5=tie, 0=solo wins")
    print("=" * 72)
    fields = []
    for r in subj_results:
        if not r.get("sut_ok"):
            print(f"{r['id']}: SUT FAILED ({r.get('error')})")
            continue
        print(f"\n{r['id']}:")
        for m in r["matchups"]:
            s = m["fused_score"]
            s_txt = f"{s:.2f}" if s is not None else "—"
            print(f"   fused vs {m['opponent']:<14} {s_txt}  "
                  f"(judges: {','.join(m['judge_families'])}, {m['n_votes']} votes)")
        if r["fused_winrate_vs_field"] is not None:
            fields.append(r["fused_winrate_vs_field"])
            tough = r["vs_toughest"]
            print(f"   → vs field: {r['fused_winrate_vs_field']:.2f}   "
                  f"vs toughest ({tough['opponent']}): {tough['fused_score']:.2f}")
    if fields:
        print(f"\n  mean fused win-rate vs field across items: "
              f"{sum(fields)/len(fields):.2f}  (0.5 = no better than the panel)")


def parse_grader(spec: str):
    prov, _, model = spec.partition(":")
    return {"provider": prov.strip(), "model": model.strip()}


def report_draco(results, grade_solos):
    print("\n" + "=" * 72)
    print("DRACO  (Perplexity deep-research rubric — official per-criterion scoring)")
    print("  normalized 0–100; fused vs each solo graded on the SAME rubric")
    print("=" * 72)
    fused_scores, solo_agg = [], {}
    beats = ties = total_cmp = 0
    for r in results:
        if not r.get("sut_ok"):
            print(f"{r['id'][:8]} ({r['domain']}): SUT FAILED ({r.get('error')})")
            continue
        fs = r["fused"]["score"]
        fused_scores.append(fs)
        line = f"{r['id'][:8]}  {r['domain'][:20]:<20} fused {fs:5.1f}"
        if grade_solos and r["solos"]:
            parts, best, bestm = [], None, None
            for m, e in r["solos"].items():
                sc = e.get("score")
                parts.append(f"{m}={sc:.1f}" if sc is not None else f"{m}=—")
                if sc is not None:
                    solo_agg.setdefault(m, []).append(sc)
                    if best is None or sc > best:
                        best, bestm = sc, m
            line += "   solos: " + ", ".join(parts)
            if best is not None:
                total_cmp += 1
                if fs > best + 1e-9:
                    beats += 1
                    tag = "fused>best"
                elif abs(fs - best) <= 1e-9:
                    ties += 1
                    tag = "tie"
                else:
                    tag = "fused<best"
                line += f"   [{tag} vs {bestm}]"
        ug = r["fused"].get("ungraded", 0)
        if ug:
            line += f"  (⚠ {ug} ungraded)"
        print(line)
    if fused_scores:
        print("-" * 72)
        print(f"mean fused: {sum(fused_scores)/len(fused_scores):.1f}")
        if grade_solos and solo_agg:
            for m, xs in solo_agg.items():
                print(f"mean {m}:  {sum(xs)/len(xs):.1f}")
            if total_cmp:
                verdict = ("fused ≥ best-solo overall" if beats + ties >= total_cmp - beats
                           else "fused sometimes < best-solo")
                print(f"\nper-task: fused beat best-solo on {beats}/{total_cmp} "
                      f"({ties} ties)  →  {verdict}")
    print("\nNOTE: this is OUR scry on DRACO's scale — NOT a reproduction of "
          "OpenRouter's headline (different models / Exa retrieval / judge).")


# --------------------------------------------------------------------------- #

def main() -> int:
    ap = argparse.ArgumentParser(prog="scry-eval",
                                 description="Measure whether scry beats the best single model.")
    ap.add_argument("--scry", default=str(HERE / "scry"), help="path to the scry CLI")
    ap.add_argument("--dataset", default=str(HERE / "eval" / "dataset.json"))
    ap.add_argument("--only", choices=["objective", "subjective", "both"], default="both")
    ap.add_argument("--limit", type=int, default=0, help="first N items per regime (0 = all)")
    ap.add_argument("--concurrency", type=int, default=4, help="max parallel judge calls")
    ap.add_argument("--no-web", action="store_true", help="run the SUT with --no-web")
    ap.add_argument("--out", default=str(HERE / "eval" / "results.json"))
    # DRACO regime (Perplexity deep-research rubric — the benchmark OpenRouter headlines)
    ap.add_argument("--draco", action="store_true",
                    help="run the DRACO rubric regime instead of objective/subjective")
    ap.add_argument("--draco-dataset", default=str(HERE / "eval" / "draco-test.jsonl"))
    ap.add_argument("--draco-tasks", type=int, default=0, help="first N DRACO tasks (0 = all 100)")
    ap.add_argument("--draco-stratified", action="store_true", help="one task per domain")
    ap.add_argument("--grader", default="codex",
                    help="grader for DRACO criteria: 'codex', 'agy:Gemini 3.1 Pro (High)' "
                         "(closest to DRACO's own Gemini judge), or 'claude:opus'")
    ap.add_argument("--grade-solos", action="store_true",
                    help="also grade each solo answer (default: fused only) — multiplies cost")
    ap.add_argument("--criteria-limit", type=int, default=0,
                    help="cap criteria per task (SMOKE ONLY; 0 = all ~39 — scores are "
                         "only meaningful with the full rubric)")
    ap.add_argument("--grader-concurrency", type=int, default=5,
                    help="max parallel DRACO grading calls")
    ap.add_argument("--grader-mode", choices=["one-shot", "per-criterion"], default="one-shot",
                    help="one-shot = all criteria in ONE call per output (default; ~1/N the tokens, "
                         "fits a subscription quota); per-criterion = one call each (marginally more "
                         "accurate but token-heavy — exhausts subscription quotas on big rubrics)")
    ap.add_argument("--no-resume", action="store_true",
                    help="DRACO: ignore any existing checkpoint and start fresh")
    args = ap.parse_args()

    scry_path = Path(args.scry).resolve()
    if not scry_path.exists():
        ap.error(f"scry not found at {scry_path}")
    mod = load_scry_module(scry_path)
    cfg = mod.load_config(None)
    model_names = [m.get("label", m["provider"]) for m in cfg.get("panel", [])]
    extra_args = ["--no-web"] if args.no_web else []

    print(f"scry-eval: panel = {', '.join(model_names)}   "
          f"aggregator = {cfg['aggregator']['provider']}:{cfg['aggregator'].get('model','')}",
          file=sys.stderr)

    # ---- DRACO regime ----
    if args.draco:
        draco_path = Path(args.draco_dataset)
        if not draco_path.exists():
            ap.error(f"DRACO dataset not found at {draco_path} — download test.jsonl from "
                     f"huggingface.co/datasets/perplexity-ai/draco")
        grader = parse_grader(args.grader)
        items = load_draco(str(draco_path), args.draco_tasks, args.draco_stratified,
                           args.criteria_limit)
        out_path = args.out
        if Path(out_path).name == "results.json":          # don't clobber obj/subj results
            out_path = str(HERE / "eval" / "draco-results.json")

        # Resume from a prior (possibly rate-limited) run: keep completed tasks,
        # re-run only the rest. --no-resume forces a clean run.
        prior, done = [], set()
        if not args.no_resume and Path(out_path).exists():
            try:
                prev = json.loads(Path(out_path).read_text())
                if prev.get("grade_solos") == args.grade_solos:
                    prior = prev.get("results", [])
                    done = {r["id"] for r in prior if task_complete(r)}
            except (OSError, ValueError):
                pass
        todo = [it for it in items if it["id"] not in done]
        if done:
            print(f"resume: {len(done)} task(s) already complete, {len(todo)} to run",
                  file=sys.stderr)

        def save_cb(results, grade_calls, partial=True):
            payload = {"regime": "draco", "panel": model_names,
                       "aggregator": cfg["aggregator"], "grader": grader,
                       "grade_solos": args.grade_solos, "partial": partial,
                       "results": results, "grading_calls": grade_calls}
            tmp = out_path + ".tmp"
            Path(tmp).write_text(json.dumps(payload, ensure_ascii=False, indent=2))
            os.replace(tmp, out_path)          # atomic — never leaves a half-written file

        print(f"DRACO: {len(todo)} task(s) to run  grader={grader['provider']}:{grader.get('model','')} "
              f"({args.grader_mode})  {'fused+solos' if args.grade_solos else 'fused-only'}"
              + (f"  criteria≤{args.criteria_limit} (SMOKE)" if args.criteria_limit else ""),
              file=sys.stderr)
        t0 = time.time()
        draco_results, grade_calls = asyncio.run(
            eval_draco(mod, cfg, scry_path, todo, extra_args, grader,
                       args.grader_concurrency, args.grade_solos,
                       grader_mode=args.grader_mode, initial_results=prior, save_cb=save_cb))
        elapsed = time.time() - t0
        save_cb(draco_results, grade_calls, partial=False)   # final, complete write
        report_draco(draco_results, args.grade_solos)
        n_scry = len([r for r in draco_results if r.get("sut_ok")])
        print(f"\ncost: {n_scry} scry runs (~{n_scry*4}-{n_scry*5} model calls) + "
              f"{grade_calls} grading calls this run   wall: {elapsed:.0f}s")
        print(f"wrote {out_path}", file=sys.stderr)
        return 0

    # ---- objective / subjective regimes ----
    ds = json.loads(Path(args.dataset).read_text())

    def take(key):
        items = ds.get(key, [])
        return items[: args.limit] if args.limit else items

    t0 = time.time()
    obj_results, subj_results, judge_calls = [], [], 0
    if args.only in ("objective", "both"):
        obj_results = eval_objective(scry_path, take("objective"), extra_args)
    if args.only in ("subjective", "both"):
        subj_results, judge_calls = asyncio.run(
            eval_subjective(mod, cfg, scry_path, take("subjective"), extra_args, args.concurrency))
    elapsed = time.time() - t0

    report(obj_results, subj_results, model_names)

    n_scry = len([r for r in obj_results + subj_results if r.get("sut_ok")])
    print(f"\ncost: {n_scry} scry runs (~{n_scry * 4}-{n_scry * 5} model calls) + "
          f"{judge_calls} judge calls   wall: {elapsed:.0f}s")
    print("NOTE: pilot N — this validates the method and shows direction, "
          "not a statistically powered result.")

    out = {"panel": model_names, "aggregator": cfg["aggregator"],
           "objective": obj_results, "subjective": subj_results,
           "judge_calls": judge_calls, "seconds": round(elapsed, 1)}
    Path(args.out).write_text(json.dumps(out, ensure_ascii=False, indent=2))
    print(f"wrote {args.out}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
