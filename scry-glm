#!/usr/bin/env python3
"""scry-glm — minimal headless adapter for Zhipu/Z.ai's OpenAI-compatible GLM API.

scry is built to drive *subscription* CLIs (claude/codex/agy/kimi) with no API keys.
GLM (Zhipu AI / Z.ai) has no first-party subscription CLI — its canonical direct
integration is the OpenAI-compatible chat API — so this shim lets scry treat GLM as
a provider. Like scry-deepseek, it needs an API key: set GLM_API_KEY (get one at
https://z.ai/manage-apikey/apikey-list). See README ("The API-key providers:
DeepSeek and GLM").

scry calls it like any text provider:
    echo "<prompt>" | scry-glm --model glm-5.2 [--system "<sys>"] [--web]
It reads the prompt on stdin and prints the assistant message to stdout.
Errors go to stderr with a non-zero exit (HTTP status in the message, so scry's
retry/backoff sees "429"/"rate"/etc.). Standard library only.

Unlike DeepSeek, GLM has a BUILT-IN web_search tool: with --web (scry's web-on
cap), the request injects it into `tools` and the model answers with live grounding;
without it, GLM answers from model knowledge only.
"""
import argparse
import json
import os
import sys
import urllib.error
import urllib.request


# GLM's chat API silently caps max_tokens low when omitted, truncating long
# answers. We instead request the chosen model's documented maximum so nothing is
# cut off — a ceiling is free (the model stops when done).
GLM_MAX_OUTPUT = {
    "glm-5.2": 131072,    # GLM-5.2: ~1M context, ~128K (131072) max output
}
DEFAULT_MAX_OUTPUT = 131072    # safe documented ceiling for unknown ids


def resolve_max_tokens(explicit, model):
    """Output-token ceiling to request: an explicit --max-tokens if given, else
    the model's documented maximum (never the API's silent low default)."""
    if explicit:
        return explicit
    return GLM_MAX_OUTPUT.get(model, DEFAULT_MAX_OUTPUT)


# Models that cannot accept reasoning_effort/thinking. GLM-5.2 always thinks when
# an effort is requested, so this is empty; kept for parity with scry-deepseek and
# to gate any future non-thinking GLM id.
NON_THINKING_MODELS: set = set()


def thinking_payload(model, effort):
    """Reasoning fields to merge into the request body for a thinking-capable model:
    `reasoning_effort` and `thinking` go at the TOP LEVEL of the body. Returns {}
    when no effort is requested or the model can't think, so a non-thinking model is
    never sent fields it would reject. The effort string is forwarded as-is (GLM
    accepts max|xhigh|high|medium|low|minimal|none)."""
    if not effort or model in NON_THINKING_MODELS:
        return {}
    return {"reasoning_effort": effort, "thinking": {"type": "enabled"}}


def web_search_payload(web, engine="search_pro_jina", count=10):
    """The built-in web_search tool to merge into the request body when web is on.
    GLM runs the search server-side and grounds its answer — no external search
    provider or function-call loop needed (this is what DeepSeek lacks). Returns {}
    when web is off, so a knowledge-only call sends no `tools`. `engine` is the
    Z.ai search backend (international default 'search_pro_jina'; on the mainland
    open.bigmodel.cn endpoint use e.g. 'search_pro'/'search_std')."""
    if not web:
        return {}
    return {"tools": [{
        "type": "web_search",
        "web_search": {
            "enable": True,
            "search_engine": engine,
            "count": count,
            "search_recency_filter": "noLimit",
            "content_size": "high",
        },
    }]}


def _config_dir() -> str:
    """scry's per-user config home — same as scry core's _global_config_path
    (~/.config/scry). Like it, we do NOT honor XDG_CONFIG_HOME, so this .env sits
    beside scry's own config.json."""
    return os.path.join(os.path.expanduser("~"), ".config", "scry")


def _env_file_candidates(script_path: str) -> list:
    """The .env files to try, in precedence order (first to define a key wins).
    A real environment variable still beats all of these (see _apply_env_file)."""
    cands = []
    override = os.environ.get("SCRY_ENV_FILE")
    if override:
        cands.append(override)
    d_abs = os.path.dirname(os.path.abspath(script_path))
    cands.append(os.path.join(d_abs, ".env"))
    d_real = os.path.dirname(os.path.realpath(script_path))
    if d_real != d_abs:
        cands.append(os.path.join(d_real, ".env"))
    cands.append(os.path.join(_config_dir(), ".env"))
    return cands


def _apply_env_file(path: str) -> None:
    """Load KEY=VALUE lines from `path` into os.environ WITHOUT overriding keys
    already set, so an explicit export / CI secret / higher-priority .env wins.
    A missing or unreadable file is a no-op."""
    try:
        with open(path) as f:
            lines = f.readlines()
    except OSError:
        return
    for raw in lines:
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if key and key not in os.environ:
            os.environ[key] = val


def _load_env_file(script_path: str = __file__) -> None:
    """Populate os.environ from the .env candidates that exist, in precedence
    order: $SCRY_ENV_FILE, then a `.env` next to this script (and its realpath,
    for symlinked installs), then ~/.config/scry/.env. Looked up by the script's
    own path / config dir, never cwd, since scry runs providers from a throwaway
    temp dir. Keeps scry zero-dependency — no python-dotenv. The key lives only in
    this process — it never enters scry's other subprocesses (claude/codex/agy/kimi)."""
    for path in _env_file_candidates(script_path):
        _apply_env_file(path)


MISSING_KEY_MSG = (
    "scry-glm: GLM_API_KEY not set — this provider needs an API key.\n"
    "Get one at https://z.ai/manage-apikey/apikey-list, then set it via any of:\n"
    "  - ~/.config/scry/.env        (recommended; read in every shell, cron, CI, Claude Code)\n"
    "  - $SCRY_ENV_FILE             (explicit path to a .env)\n"
    "  - a .env next to scry-glm\n"
    "  - export GLM_API_KEY=...      (note: ~/.zshrc is read ONLY by interactive shells,\n"
    "                                 so headless `scry plan` won't see it — use ~/.zshenv)\n"
    'See README: "The API-key providers: DeepSeek and GLM".\n'
)


def main() -> int:
    _load_env_file()
    ap = argparse.ArgumentParser(prog="scry-glm", add_help=True)
    ap.add_argument("--model", default="glm-5.2",
                    help="GLM model id (e.g. glm-5.2)")
    ap.add_argument("--system", default=None, help="optional system prompt")
    ap.add_argument("--timeout", type=float, default=300.0)
    ap.add_argument("--max-tokens", type=int, default=None)
    ap.add_argument("--reasoning-effort", default=None,
                    help="GLM reasoning effort for thinking models (e.g. high|max)")
    ap.add_argument("--web", action="store_true",
                    help="enable GLM's built-in web_search tool (live grounding)")
    ap.add_argument("--search-engine",
                    default=os.environ.get("GLM_SEARCH_ENGINE", "search_pro_jina"),
                    help="web_search backend (default search_pro_jina or $GLM_SEARCH_ENGINE)")
    ap.add_argument("--base-url", default=os.environ.get("GLM_BASE_URL",
                                                         "https://api.z.ai/api/paas/v4"),
                    help="API base (default https://api.z.ai/api/paas/v4 or $GLM_BASE_URL)")
    args = ap.parse_args()

    key = os.environ.get("GLM_API_KEY")
    if not key:
        sys.stderr.write(MISSING_KEY_MSG)
        return 2

    prompt = sys.stdin.read()
    if not prompt.strip():
        sys.stderr.write("scry-glm: empty prompt on stdin\n")
        return 2

    messages = []
    if args.system:
        messages.append({"role": "system", "content": args.system})
    messages.append({"role": "user", "content": prompt})
    payload = {"model": args.model, "messages": messages, "stream": False,
               "max_tokens": resolve_max_tokens(args.max_tokens, args.model),
               **thinking_payload(args.model, args.reasoning_effort),
               **web_search_payload(args.web, args.search_engine)}

    url = args.base_url.rstrip("/") + "/chat/completions"
    req = urllib.request.Request(
        url, data=json.dumps(payload).encode(), method="POST",
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json",
                 "Accept-Language": "en-US,en"})

    try:
        with urllib.request.urlopen(req, timeout=args.timeout) as resp:
            body = json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        detail = ""
        try:
            detail = e.read().decode(errors="replace")[:400]
        except Exception:  # noqa: BLE001
            pass
        # Include the status code so scry's transient-error retry can match (429/5xx).
        sys.stderr.write(f"scry-glm: HTTP {e.code} {e.reason}: {detail}\n")
        return 1
    except urllib.error.URLError as e:
        sys.stderr.write(f"scry-glm: connection error: {e.reason}\n")
        return 1
    except Exception as e:  # noqa: BLE001
        sys.stderr.write(f"scry-glm: {e}\n")
        return 1

    try:
        text = body["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError):
        sys.stderr.write(f"scry-glm: unexpected response: {json.dumps(body)[:400]}\n")
        return 1

    if not text:
        sys.stderr.write("scry-glm: empty completion\n")
        return 1
    sys.stdout.write(text)
    return 0


if __name__ == "__main__":
    sys.exit(main())
